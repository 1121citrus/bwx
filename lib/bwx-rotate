# Rotate a time-limited secret using its provider driver.
#
# Reads the provider: field from the secret's BWS note to determine
# which driver to use.  Falls back to the "prompt" driver when no
# provider: field is set.
#
# After the provider generates a new credential, this function
# updates the BWS value, expires:, and note metadata automatically.
#
# Args:
#   SECRET   Secret name or UUID (required)
#   PROJECT  Project name or UUID (optional)
# Returns:
#   0 on success; non-zero on failure
bwx-rotate() {
    set -o errexit -o errtrace -o nounset -o pipefail
    # DEBUG xtrace intentionally omitted — PROVIDER_VALUE and secret
    # values flow through this function and would leak via xtrace.
    # Use structured trace/debug calls for debugging.

    local dryrun=false
    local rotate_all=false

    while [[ $# -gt 0 && "${1}" == -* ]]; do
        case "${1}" in
            -h|--help)
                cat <<EOF
Usage: bwx rotate [options] SECRET [PROJECT]
       bwx rotate --all [PROJECT]

Rotate a time-limited secret using its provider driver.

The provider is determined by the provider: field in the secret's
BWS note.  When no provider is set, the generic "prompt" driver
asks the operator to paste the new value.

Arguments:
  SECRET       Secret name or UUID
  PROJECT      Project name or UUID (default: \${BWX_DEFAULT_PROJECT})

Options:
  --all                  Rotate all secrets with an expires: field
  --dry-run              Show what would be done
  -l, --log-level LEVEL  Set log level (default: info)
  -h, --help             Show this help and exit

Built-in providers (automated):
  aws-iam                AWS IAM access key rotation via aws CLI
  bitwarden-api-key      Machine account token via Bitwarden API
  docker-registry        Docker Hub access token via Hub API
  grafana-service-account  Grafana SA token via HTTP API
  mqtt-password          Random alphanumeric MQTT broker password
  openssl-selfsigned     Self-signed TLS certificate/key via openssl
  password-generate      Random password (configurable length/charset)
  tailscale-oauth        Tagged pre-auth key via OAuth credentials

Built-in providers (interactive):
  anthropic-api-key      Paste API key with sk-ant- validation
  github-pat             Paste token from GitHub developer settings
  letsencrypt-manual     Paste PEM certificate with format validation
  tailscale-manual       Paste key from Tailscale admin console
  prompt                 Generic: asks for value and expiry (default)

See doc/providers.md for configuration and credential passing.
EOF
                return "${EXIT_USAGE:-2}"
                ;;
            --all)
                rotate_all=true
                shift
                ;;
            --dry-run)
                dryrun=true
                shift
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift; break ;;
            -*)
                error "${EXIT_USAGE}" "Unknown option: ${1}" ;;
        esac
    done

    if is-true "${rotate_all}"; then
        local project="${1:-}"
        _bwx_rotate_all "${project}" "${dryrun}"
        return $?
    fi

    local secret="${1:-}"
    local project="${2:-}"
    [[ -n "${secret}" ]] || error "${EXIT_USAGE}" "SECRET required (or use --all)"

    _bwx_rotate_one "${secret}" "${project}" "${dryrun}"
}

# Rotate a single secret.
# Args:
#   $1 — secret name or UUID
#   $2 — project (may be empty for default)
#   $3 — dryrun flag
# Returns:
#   0 on success
_bwx_rotate_one() {
    local secret="${1}" project="${2}" dryrun="${3}"

    # Resolve the note to find the provider
    local note provider
    if [[ -n "${project}" ]]; then
        note="$(bwx-secret-get note "${secret}" "${project}" 2>/dev/null)" || note=""
    else
        note="$(bwx-secret-get note "${secret}" 2>/dev/null)" || note=""
    fi

    provider="$(bwx-note-get-field provider "${note}")"
    provider="${provider:-prompt}"

    info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    info "Rotating ${secret} (provider: ${provider})"

    # Validate provider name before constructing path (prevent traversal)
    [[ "${provider}" =~ ^[a-zA-Z0-9_-]+$ ]] || \
        error "${EXIT_ERROR}" "Invalid provider name '${provider}' for secret '${secret}'"

    local provider_file
    provider_file="$(dirname "${BASH_SOURCE[0]}")/providers/${provider}"
    if [[ ! -f "${provider_file}" ]]; then
        error "${EXIT_ERROR}" "Unknown provider '${provider}' for secret '${secret}'"
    fi
    source "${provider_file}"

    local provider_fn="bwx-provider-${provider}"
    if ! declare -F "${provider_fn}" >/dev/null 2>&1; then
        error "${EXIT_ERROR}" "Provider '${provider}' does not define ${provider_fn}()"
    fi

    if is-true "${dryrun}"; then
        info "[dry-run] Would call ${provider_fn} for ${secret}"
        return 0
    fi

    # Lazy-source provider config helpers
    if ! declare -F bwx-provider-config >/dev/null 2>&1; then
        source "$(dirname "${BASH_SOURCE[0]}")/../include/provider-config"
    fi

    # Call the provider — it sets PROVIDER_VALUE, PROVIDER_EXPIRES, PROVIDER_NOTE
    PROVIDER_VALUE="" PROVIDER_EXPIRES="" PROVIDER_NOTE=""
    "${provider_fn}" "${secret}" "${BWX_SECRETS_DIR:-.secrets}" "${note}" \
        || return $?

    [[ -n "${PROVIDER_VALUE}" ]] || \
        error "${EXIT_ERROR}" "Provider '${provider}' returned empty value"
    [[ -n "${PROVIDER_EXPIRES}" ]] || \
        error "${EXIT_ERROR}" "Provider '${provider}' returned empty expiry"
    [[ "${PROVIDER_EXPIRES}" =~ ^[0-9]+$ ]] || \
        error "${EXIT_ERROR}" "Provider '${provider}' returned non-numeric expiry: '${PROVIDER_EXPIRES}'"
    [[ "${PROVIDER_EXPIRES}" -gt 0 ]] || \
        error "${EXIT_ERROR}" "Provider '${provider}' returned zero-day expiry"

    # Compute expires date
    local expires_date
    local target_epoch=$(( $(date -u +%s) + PROVIDER_EXPIRES * 86400 ))
    expires_date="$(date -u -d "@${target_epoch}" +%Y-%m-%d 2>/dev/null \
        || date -u -r "${target_epoch}" +%Y-%m-%d 2>/dev/null \
        || date -u -j -f "%s" "${target_epoch}" +%Y-%m-%d)"

    # Update BWS
    info "Updating BWS secret ${secret}"
    if [[ -n "${project}" ]]; then
        bwx-secret-set value "${secret}" "${PROVIDER_VALUE}" "${project}"
    else
        bwx-secret-set value "${secret}" "${PROVIDER_VALUE}"
    fi

    # Update the note: remove rotation-owned fields, then append new values.
    # All other fields (including unknown future fields) are preserved.
    local new_note="${note}"
    new_note="$(bwx-note-remove-field expires "" "${new_note}")"
    new_note="$(bwx-note-remove-field provider "" "${new_note}")"
    if [[ -n "${PROVIDER_NOTE}" ]]; then
        new_note="$(bwx-note-remove-field note "" "${new_note}")"
        new_note+=$'\n'"${PROVIDER_NOTE}"
    fi
    new_note+=$'\n'"expires: ${expires_date}"
    new_note+=$'\n'"provider: ${provider}"

    if [[ -n "${project}" ]]; then
        bwx-secret-set note "${secret}" "${new_note}" "${project}"
    else
        bwx-secret-set note "${secret}" "${new_note}"
    fi

    info "${secret} rotated successfully (expires ${expires_date})"
}

# Rotate all secrets with an expires: field.
# Args:
#   $1 — project (may be empty)
#   $2 — dryrun flag
# Returns:
#   0 if all succeed
_bwx_rotate_all() {
    local project="${1}" dryrun="${2}"
    local failed=0

    local candidates_file
    candidates_file="$(mktemp)" || \
        error "${EXIT_ERROR}" "Cannot create temp file for candidate list"
    # shellcheck disable=SC2064
    trap "rm -f '${candidates_file}'" RETURN

    if ! _bwx_default_secret_notes "${project}" > "${candidates_file}"; then
        error "${EXIT_ERROR}" "Failed to fetch secret list for rotation"
    fi

    local key note expires_date
    while IFS= read -r -d '' key && IFS= read -r -d '' note; do
        expires_date="$(bwx-note-get-field expires "${note}")"
        [[ -n "${expires_date}" ]] || continue

        _bwx_rotate_one "${key}" "${project}" "${dryrun}" || \
            failed=$((failed + 1))
    done < "${candidates_file}"

    info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if [[ "${failed}" -gt 0 ]]; then
        error "${EXIT_ERROR}" "${failed} rotation(s) failed"
    fi
    info "All rotations complete"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bwx-rotate "$@"
fi
