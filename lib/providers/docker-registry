# Docker Hub access token rotation — automated via Hub API.
# Creates a new personal access token and returns it.
# Note fields (parsed via bwx-provider-config):
#   docker-token-label:  label for the new token (default: "bwx-rotated")
#   docker-hub-username: Hub username — credential
#   docker-hub-password: Hub password or existing PAT — credential
# Credential fields support BWS references (project:secret),
# file paths (./path), env vars (@env:VAR), or literal values.
# Falls back to secrets directory files when note fields are absent.
# Args:
#   $1 — secret name (for display)
#   $2 — secrets directory (fallback for credential files)
#   $3 — current BWS note contents (for config fields)
# Returns:
#   0; sets PROVIDER_VALUE, PROVIDER_EXPIRES, PROVIDER_NOTE
bwx-provider-docker-registry() {
    local secret="${1}" secrets_dir="${2}" note="${3:-}"
    local hub_api="https://hub.docker.com/v2"

    local token_label
    token_label="$(bwx-provider-config docker-token-label \
        "${note}" "bwx-rotated" "string")"

    # Credential fields with secrets-directory fallback
    local username password
    username="$(bwx-provider-config docker-hub-username \
        "${note}" "" "credential" 2>/dev/null)" || {
        local user_file="${secrets_dir}/docker-hub-username"
        if [[ -f "${user_file}" ]]; then
            username="$(<"${user_file}")"
        else
            warn "Docker Hub credentials not found"
            warn "Set docker-hub-username in note or store at:"
            warn "  ${user_file}"
            return 1
        fi
    }

    password="$(bwx-provider-config docker-hub-password \
        "${note}" "" "credential" 2>/dev/null)" || {
        local pw_file="${secrets_dir}/docker-hub-password"
        if [[ -f "${pw_file}" ]]; then
            password="$(<"${pw_file}")"
        else
            warn "Docker Hub credentials not found"
            warn "Set docker-hub-password in note or store at:"
            warn "  ${pw_file}"
            return 1
        fi
    }

    info "Authenticating with Docker Hub..."
    local login_payload login_response jwt
    login_payload="$(jq -n \
        --arg u "${username}" \
        --arg p "${password}" \
        '{ username: $u, password: $p }'
    )"

    login_response="$(curl --fail --silent --show-error \
        --request POST \
        --url "${hub_api}/users/login" \
        --header "Content-Type: application/json" \
        --data "${login_payload}" \
        2>&1)" \
        || { error "${EXIT_ERROR}" \
                 "Docker Hub login failed: ${login_response}"
             return 1; }

    jwt="$(printf '%s' "${login_response}" \
        | jq -r '.token // empty')"

    if [[ -z "${jwt}" ]]; then
        error "${EXIT_ERROR}" "Docker Hub login returned no token"
        return 1
    fi

    local full_label
    full_label="${token_label}-$(date +%Y%m%d-%H%M%S)"
    info "Creating Docker Hub access token '${full_label}'..."
    local token_payload token_response
    token_payload="$(jq -n \
        --arg label "${full_label}" \
        '{ token_label: $label, scopes: ["repo:admin"] }'
    )"

    token_response="$(curl --fail --silent --show-error \
        --request POST \
        --url "${hub_api}/access-tokens" \
        --header "Authorization: Bearer ${jwt}" \
        --header "Content-Type: application/json" \
        --data "${token_payload}" \
        2>&1)" \
        || { error "${EXIT_ERROR}" \
                 "Token creation failed: ${token_response}"
             return 1; }

    local new_token
    new_token="$(printf '%s' "${token_response}" \
        | jq -r '.token // empty')"

    if [[ -z "${new_token}" ]]; then
        error "${EXIT_ERROR}" \
            "API response did not contain an access token"
        return 1
    fi

    PROVIDER_VALUE="${new_token}"
    PROVIDER_EXPIRES=365
    PROVIDER_NOTE="note: Docker Hub PAT ${full_label}"
}
