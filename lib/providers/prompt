# Generic prompt provider — asks the operator to paste a new value.
# Used as the fallback when no provider: field is set in the note.
# Args:
#   $1 — secret name (for display)
# Returns:
#   0; sets PROVIDER_VALUE, PROVIDER_EXPIRES, PROVIDER_NOTE
bwx-provider-prompt() {
    local secret="${1}"

    info "Paste the new value for '${secret}'."
    info "(The secret's current note and expiry are shown above.)"
    printf '\n' >&2

    local value
    printf 'New value: ' >/dev/tty 2>/dev/null || true
    if [[ -n "${BWX_TTY_FD:-}" ]]; then
        IFS= read -r value <&"${BWX_TTY_FD}"
    else
        IFS= read -r value </dev/tty
    fi
    [[ -n "${value}" ]] || { error "${EXIT_ERROR}" "No value provided"; return 1; }

    local days
    printf 'Expiry in days [90]: ' >/dev/tty 2>/dev/null || true
    if [[ -n "${BWX_TTY_FD:-}" ]]; then
        IFS= read -r days <&"${BWX_TTY_FD}"
    else
        IFS= read -r days </dev/tty
    fi
    days="${days:-90}"
    [[ "${days}" =~ ^[0-9]+$ && "${days}" -gt 0 ]] || \
        { error "${EXIT_ERROR}" "Expiry must be a positive integer"; return 1; }

    PROVIDER_VALUE="${value}"
    PROVIDER_EXPIRES="${days}"
    PROVIDER_NOTE=""
}
