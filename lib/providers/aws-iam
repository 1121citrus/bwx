# AWS IAM access key rotation — fully automated via AWS CLI.
# Creates a new access key, returns the secret key, and deactivates
# the old key. Requires the aws CLI (or Docker-wrapped equivalent)
# with iam:CreateAccessKey, iam:ListAccessKeys, and
# iam:UpdateAccessKey permissions.
# Note fields (parsed via bwx-provider-config):
#   aws-iam-username:       IAM username to rotate (default: caller's own keys)
#   aws-access-key-id:      access key for AWS API authentication — credential
#   aws-secret-access-key:  secret key for AWS API authentication — credential
#   aws-region:             AWS region (default: us-east-1)
# Credential fields support BWS references (project:secret),
# file paths (./path), env vars (@env:VAR), or literal values.
# When credential fields are absent, falls back to the AWS CLI
# native credential chain (~/.aws/, environment variables).
# Args:
#   $1 — secret name (for display)
#   $2 — secrets directory (fallback for credential files)
#   $3 — current BWS note contents (for config fields)
# Returns:
#   0; sets PROVIDER_VALUE, PROVIDER_EXPIRES, PROVIDER_NOTE
bwx-provider-aws-iam() {
    local secret="${1}" secrets_dir="${2}" note="${3:-}"

    if ! command -v aws >/dev/null 2>&1 \
            && ! command -v docker >/dev/null 2>&1; then
        error "${EXIT_ERROR}" \
            "Neither aws CLI nor docker found (one is required)"
        return 1
    fi

    # Resolve config fields from note
    local iam_username aws_key_id aws_secret_key aws_region
    iam_username="$(bwx-provider-config aws-iam-username \
        "${note}" "" "string" 2>/dev/null)" || iam_username=""

    aws_region="$(bwx-provider-config aws-region \
        "${note}" "us-east-1" "string")"

    # Credential fields with secrets-directory fallback.
    # When neither note field nor secrets file exists, the variable
    # stays empty and the provider falls through to the AWS CLI
    # native credential chain (~/.aws/, environment variables).
    aws_key_id="$(bwx-provider-config aws-access-key-id \
        "${note}" "" "credential" 2>/dev/null)" || {
        local key_file="${secrets_dir}/aws-access-key-id"
        if [[ -f "${key_file}" ]]; then
            aws_key_id="$(<"${key_file}")"
        else
            aws_key_id=""
        fi
    }

    aws_secret_key="$(bwx-provider-config aws-secret-access-key \
        "${note}" "" "credential" 2>/dev/null)" || {
        local secret_file="${secrets_dir}/aws-secret-access-key"
        if [[ -f "${secret_file}" ]]; then
            aws_secret_key="$(<"${secret_file}")"
        else
            aws_secret_key=""
        fi
    }

    # Inject credentials into the process environment
    if [[ -n "${aws_key_id}" && -n "${aws_secret_key}" ]]; then
        export AWS_ACCESS_KEY_ID="${aws_key_id}"
        export AWS_SECRET_ACCESS_KEY="${aws_secret_key}"
    elif [[ -n "${aws_key_id}" || -n "${aws_secret_key}" ]]; then
        error "${EXIT_ERROR}" \
            "Both aws-access-key-id and aws-secret-access-key" \
            "are required (only one was set)"
        return 1
    fi
    export AWS_DEFAULT_REGION="${aws_region}"

    local -a user_args=()
    if [[ -n "${iam_username}" ]]; then
        user_args=(--user-name "${iam_username}")
    fi

    info "Listing current access keys..."
    local old_key_id
    old_key_id="$(aws iam list-access-keys \
        "${user_args[@]}" \
        --query 'AccessKeyMetadata[0].AccessKeyId' \
        --output text 2>&1)" \
        || { error "${EXIT_ERROR}" \
                 "Failed to list access keys: ${old_key_id}"
             return 1; }

    if [[ -z "${old_key_id}" || "${old_key_id}" == "None" ]]; then
        warn "No existing access key found; creating first key"
        old_key_id=""
    fi

    info "Creating new access key..."
    local new_creds
    new_creds="$(aws iam create-access-key \
        "${user_args[@]}" \
        --output json 2>&1)" \
        || { error "${EXIT_ERROR}" \
                 "Failed to create access key: ${new_creds}"
             return 1; }

    local new_secret_key new_key_id
    new_secret_key="$(printf '%s' "${new_creds}" \
        | jq -r '.AccessKey.SecretAccessKey')"
    new_key_id="$(printf '%s' "${new_creds}" \
        | jq -r '.AccessKey.AccessKeyId')"

    if [[ -z "${new_secret_key}" \
            || "${new_secret_key}" == "null" ]]; then
        error "${EXIT_ERROR}" "New access key value is empty"
        return 1
    fi

    if [[ -n "${old_key_id}" ]]; then
        info "Deactivating old access key ${old_key_id}..."
        aws iam update-access-key \
            "${user_args[@]}" \
            --access-key-id "${old_key_id}" \
            --status Inactive 2>&1 \
            || warn "Failed to deactivate old key ${old_key_id}"
    fi

    PROVIDER_VALUE="${new_secret_key}"
    PROVIDER_EXPIRES=365
    PROVIDER_NOTE="note: AWS IAM key ${new_key_id}"
}
