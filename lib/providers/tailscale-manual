# shellcheck shell=bash
# shellcheck disable=SC2034
# Tailscale manual provider — operator pastes key from admin console.
# Used for untagged keys (OAuth clients can only create tagged keys).

bwx-provider-tailscale-manual() {
    local secret="${1}"

    info "Generate a new key in the Tailscale admin console:"
    info "  https://login.tailscale.com/admin/settings/keys"
    printf '\n' >&2
    info "Settings:"
    info "  Reusable:  yes"
    info "  Ephemeral: no"
    info "  Tags:      none (must be untagged for user-owned devices)"
    info "  Expiry:    90 days"
    printf '\n' >&2

    local new_key
    printf 'Paste the new key: ' >/dev/tty 2>/dev/null || true
    if [[ -n "${BWX_TTY_FD:-}" ]]; then
        IFS= read -r new_key <&"${BWX_TTY_FD}"
    else
        IFS= read -r new_key </dev/tty
    fi
    [[ -n "${new_key}" ]] || { error "${EXIT_ERROR}" "No key provided"; return 1; }
    [[ "${new_key}" == tskey-auth-* ]] || \
        { error "${EXIT_ERROR}" "Key must start with tskey-auth-"; return 1; }

    PROVIDER_VALUE="${new_key}"
    PROVIDER_EXPIRES=90
    PROVIDER_NOTE="note: Untagged reusable key for server provisioning"
}
