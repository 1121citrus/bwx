# Self-signed TLS certificate generator — fully automated, no TTY.
# Generates a self-signed certificate and private key using openssl.
# For multi-artifact rotation (key + cert), assign each artifact its
# own BWS secret with provider: openssl-selfsigned and a distinct
# cert-role: note field.
# Note fields (parsed via bwx-provider-config):
#   cert-role: "cert" (default) or "key"
#   cert-cn:       common name (default: "bwx-selfsigned")
#   cert-days:     validity in days (default: 365, minimum: 1)
# Args:
#   $1 — secret name (for display)
#   $2 — secrets directory (for temporary key storage)
#   $3 — current BWS note contents (for config fields)
# Returns:
#   0; sets PROVIDER_VALUE, PROVIDER_EXPIRES, PROVIDER_NOTE
bwx-provider-openssl-selfsigned() {
    local secret="${1}" secrets_dir="${2}" note="${3:-}"

    local role cn days
    role="$(bwx-provider-config cert-role \
        "${note}" "cert" "enum:cert|key")"
    cn="$(bwx-provider-config cert-cn \
        "${note}" "bwx-selfsigned" "string")"
    days="$(bwx-provider-config cert-days \
        "${note}" "365" "integer:1:3650")"

    local tmpdir
    # SECURITY: Use a template with TMPDIR to avoid predictable names in /tmp
    tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/bwx.XXXXXX")" \
        || { error "${EXIT_ERROR}" "Failed to create temp dir"
             return 1; }
    # shellcheck disable=SC2064
    trap "rm -rf '${tmpdir}'" RETURN

    local key_file="${tmpdir}/key.pem"
    local cert_file="${tmpdir}/cert.pem"

    info "Generating self-signed certificate (CN=${cn}, ${days} days)..."
    openssl req -x509 -newkey rsa:2048 -nodes \
        -keyout "${key_file}" \
        -out "${cert_file}" \
        -days "${days}" \
        -subj "/CN=${cn}" \
        2>/dev/null \
        || { error "${EXIT_ERROR}" "openssl certificate generation failed"
             return 1; }

    if [[ "${role}" == "key" ]]; then
        PROVIDER_VALUE="$(<"${key_file}")"
    else
        PROVIDER_VALUE="$(<"${cert_file}")"
    fi

    if [[ -z "${PROVIDER_VALUE}" ]]; then
        error "${EXIT_ERROR}" "Generated ${role} is empty"
        return 1
    fi

    PROVIDER_EXPIRES="${days}"
    PROVIDER_NOTE="note: Self-signed ${role} (CN=${cn})"
}
