# Mosquitto password rotation — generates a random password.
# Produces a new random password suitable for MQTT broker
# authentication. The consuming service must update its password
# file separately (this provider sets the credential value only).
# Args:
#   $1 — secret name (for display)
#   $2 — secrets directory (unused)
# Returns:
#   0; sets PROVIDER_VALUE, PROVIDER_EXPIRES, PROVIDER_NOTE
bwx-provider-mqtt-password() {
    local secret="${1}"
    local length=32

    local password
    password="$(head -c $(( length * 3 )) /dev/urandom \
        | base64 \
        | tr -d '\n' \
        | tr -dc 'A-Za-z0-9' \
        | head -c "${length}")"

    if [[ -z "${password}" || ${#password} -lt "${length}" ]]; then
        error "${EXIT_ERROR}" \
            "Failed to generate MQTT password"
        return 1
    fi

    info "Generated ${length}-character MQTT password for '${secret}'"

    PROVIDER_VALUE="${password}"
    PROVIDER_EXPIRES=365
    PROVIDER_NOTE="note: MQTT broker password"
}
