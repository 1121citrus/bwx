# Tailscale OAuth provider — fully automated pre-auth key rotation.
# Note fields (parsed via bwx-provider-config):
#   tailscale-oauth-client-id:     OAuth client ID — credential
#   tailscale-oauth-client-secret: OAuth client secret — credential
# Credential fields support BWS references (project:secret),
# file paths (./path), env vars (@env:VAR), or literal values.
# Falls back to secrets directory files when note fields are absent.
# Args:
#   $1 — secret name (for display)
#   $2 — secrets directory (fallback for credential files)
#   $3 — current BWS note contents (for config fields)
# Returns:
#   0; sets PROVIDER_VALUE, PROVIDER_EXPIRES, PROVIDER_NOTE
bwx-provider-tailscale-oauth() {
    local secret="${1}" secrets_dir="${2}" note="${3:-}"
    local api="https://api.tailscale.com/api/v2"
    local expiry_seconds=7776000

    # Credential fields with secrets-directory fallback
    local client_id client_secret
    client_id="$(bwx-provider-config tailscale-oauth-client-id \
        "${note}" "" "credential" 2>/dev/null)" || {
        local id_file="${secrets_dir}/tailscale-oauth-client-id"
        if [[ -f "${id_file}" ]]; then
            client_id="$(<"${id_file}")"
        else
            warn "Tailscale OAuth credentials not found"
            warn "One-time setup: create an OAuth client in the"
            warn "Tailscale admin console (Settings → OAuth clients"
            warn "→ auth_keys scope), then either:"
            warn "  1. Set tailscale-oauth-client-id in the note"
            warn "  2. Store at: ${id_file}"
            return 1
        fi
    }

    client_secret="$(bwx-provider-config tailscale-oauth-client-secret \
        "${note}" "" "credential" 2>/dev/null)" || {
        local secret_file="${secrets_dir}/tailscale-oauth-client-secret"
        if [[ -f "${secret_file}" ]]; then
            client_secret="$(<"${secret_file}")"
        else
            warn "Tailscale OAuth credentials not found"
            warn "Store the client secret at:"
            warn "  ${secret_file}"
            return 1
        fi
    }

    info "Authenticating with Tailscale OAuth..."
    local token_response
    token_response="$(curl --fail --silent --show-error \
        --request POST \
        --url "${api}/oauth/token" \
        --data @- <<< "client_id=${client_id}&client_secret=${client_secret}&grant_type=client_credentials"
    )" || { error "${EXIT_ERROR}" "Tailscale OAuth token request failed"; return 1; }

    local token
    token="$(printf '%s' "${token_response}" | jq -r '.access_token')"

    info "Creating new tagged pre-auth key..."
    local key_payload key_response
    key_payload="$(jq -n \
        --argjson expiry "${expiry_seconds}" \
        '{
            capabilities: {
                devices: {
                    create: {
                        reusable: true,
                        ephemeral: false,
                        preauthorized: true,
                        tags: ["tag:switch-sidecar"]
                    }
                }
            },
            expirySeconds: $expiry,
            description: "Auto-rotated by bwx rotate"
        }'
    )"

    key_response="$(curl --fail --silent --show-error \
        --request POST \
        --url "${api}/tailnet/-/keys" \
        --header @- \
        --header "Content-Type: application/json" \
        --data "${key_payload}" \
        <<< "Authorization: Bearer ${token}"
    )" || { error "${EXIT_ERROR}" "Tailscale key creation failed"; return 1; }

    PROVIDER_VALUE="$(printf '%s' "${key_response}" | jq -r '.key')"
    PROVIDER_EXPIRES=90
    PROVIDER_NOTE="note: Tagged reusable key for switch-tailscale sidecar"
}
