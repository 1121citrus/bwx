# shellcheck shell=bash
# shellcheck disable=SC2034
# Tailscale OAuth provider — fully automated pre-auth key rotation.
# Requires OAuth client credentials in the secrets directory.

bwx-provider-tailscale-oauth() {
    local secret="${1}" secrets_dir="${2}"
    local api="https://api.tailscale.com/api/v2"
    local expiry_seconds=7776000

    local client_id_file="${secrets_dir}/tailscale-oauth-client-id"
    local client_secret_file="${secrets_dir}/tailscale-oauth-client-secret"

    if [[ ! -f "${client_id_file}" || ! -f "${client_secret_file}" ]]; then
        warn "Tailscale OAuth credentials not found"
        warn "One-time setup: create an OAuth client in the Tailscale"
        warn "admin console (Settings → OAuth clients → auth_keys scope),"
        warn "then store:"
        warn "  ${client_id_file}"
        warn "  ${client_secret_file}"
        return 1
    fi

    local client_id client_secret
    client_id="$(<"${client_id_file}")"
    client_secret="$(<"${client_secret_file}")"

    info "Authenticating with Tailscale OAuth..."
    local token_response
    token_response="$(curl --fail --silent --show-error \
        --request POST \
        --url "${api}/oauth/token" \
        --data "client_id=${client_id}&client_secret=${client_secret}&grant_type=client_credentials"
    )" || { error "${EXIT_ERROR}" "Tailscale OAuth token request failed"; return 1; }

    local token
    token="$(printf '%s' "${token_response}" | jq -r '.access_token')"

    info "Creating new tagged pre-auth key..."
    local key_payload key_response
    key_payload="$(jq -n \
        --argjson expiry "${expiry_seconds}" \
        '{
            capabilities: {
                devices: {
                    create: {
                        reusable: true,
                        ephemeral: false,
                        preauthorized: true,
                        tags: ["tag:switch-sidecar"]
                    }
                }
            },
            expirySeconds: $expiry,
            description: "Auto-rotated by bwx rotate"
        }'
    )"

    key_response="$(curl --fail --silent --show-error \
        --request POST \
        --url "${api}/tailnet/-/keys" \
        --header "Authorization: Bearer ${token}" \
        --header "Content-Type: application/json" \
        --data "${key_payload}"
    )" || { error "${EXIT_ERROR}" "Tailscale key creation failed"; return 1; }

    PROVIDER_VALUE="$(printf '%s' "${key_response}" | jq -r '.key')"
    PROVIDER_EXPIRES=90
    PROVIDER_NOTE="note: Tagged reusable key for switch-tailscale sidecar"
}
