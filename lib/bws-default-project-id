bws-default-project-id() {
    set -o errexit -o errtrace -o nounset -o pipefail
    local _debug="${DEBUG:-false}"
    [[ "${_debug,,}" =~ ^(1|on|true|t|yes|y)$ ]] && set -o verbose -o xtrace

    local refresh=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: bwx project default id [options]

Return the UUID of the default default Bitwarden Secrets Manager project.

Environment variables:
    BWS_DEFAULT_PROJECT_ID  Cached UUID value to reuse between calls
    BWS_DEFAULT_PROJECT     Cached name (consumed by bws-default-project-name)

Options:
    -h, --help     Display this help message
    -l, --log-level LEVEL  Set log level (default: info)
    --refresh      Ignore any cached UUID and fetch from Bitwarden again

EOF
                return "${EXIT_USAGE:-2}"
                ;;
            --refresh)
                refresh=true
                shift
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                declare -F error >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
                error "${EXIT_USAGE:-2}" "Unknown option '${1}'"
                break
                ;;
            *)
                declare -F error >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
                error "${EXIT_USAGE:-2}" "Too many arguments '${*}'"
                break
                ;;
        esac
    done

    # If we did this before the 'while' loop, we could avoid having to conditionally check
    # for the 'error' function in each case branch, but that would just add a bunch of overhead
    # to the --help option in order to remove 2 lines of code in the other branches, so we'll
    # just check for 'error' in each branch instead.
    declare -F error fatal trace >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"

    [[ $# -gt 0 ]] && error "${EXIT_USAGE:-2}" "Too many arguments"

    if [[ "${refresh}" == true ]]; then
        unset BWS_DEFAULT_PROJECT_ID
    fi

    if [[ -z "${BWS_DEFAULT_PROJECT_ID:-}" ]]; then
        for cmd in bws-default-project-name bws-project-list ; do
            declare -F "${cmd}" >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/${cmd}"
        done

        local project=
        project="$(bws-default-project-name)"
        trace bws-project-id "${project}"

        # Optimization: Call bws-project-list directly and filter with jq to avoid
        # intermediate script overheads (bws-project-id -> bws-project -> bws-project-list).
        if ! BWS_DEFAULT_PROJECT_ID=$(bws-project-list | jq -r --arg name "${project}" '.[] | select(.name == $name or .id == $name) | .id'); then
             fatal "${EXIT_ERROR:-1}" "Failed to lookup project '${project}'"
        fi

        [[ -z "${BWS_DEFAULT_PROJECT_ID}" ]] && fatal "${EXIT_NOTFOUND}" "BWS Default project '${project}' not found"
        export BWS_DEFAULT_PROJECT_ID
        trace "Exported BWS_DEFAULT_PROJECT_ID=${BWS_DEFAULT_PROJECT_ID}"
    fi

    echo "${BWS_DEFAULT_PROJECT_ID}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bws-default-project-id "$@"
fi
