# Return the UUID of the default project.
# Resolves BWX_DEFAULT_PROJECT via bwx-project-list; caches the
# result in BWX_DEFAULT_PROJECT_ID for subsequent calls.
# Args:
#   None
# Returns:
#   0 and writes UUID to stdout; EXIT_CONFIG if no default is set
bwx-default-project-id() {
    set -o errexit -o errtrace -o nounset -o pipefail
    # DEBUG xtrace omitted — secret values may flow through callee chain

    local refresh=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: bwx project default id [options]

Return the UUID of the default Bitwarden Secrets Manager project.

Environment variables:
    BWX_DEFAULT_PROJECT_ID  Cached UUID value to reuse between calls
    BWX_DEFAULT_PROJECT     Cached name (consumed by bwx-default-project-name)

Options:
    -h, --help     Display this help message
    -l, --log-level LEVEL  Set log level (default: info)
    --refresh      Ignore any cached UUID and fetch from Bitwarden again

EOF
                return "${EXIT_USAGE:-2}"
                ;;
            --refresh)
                refresh=true
                shift
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                declare -F error >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
                error "${EXIT_USAGE:-2}" "Unknown option '${1}'"
                break
                ;;
            *)
                declare -F error >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
                error "${EXIT_USAGE:-2}" "Too many arguments '${*}'"
                break
                ;;
        esac
    done

    # If we did this before the 'while' loop, we could avoid having to conditionally check
    # for the 'error' function in each case branch, but that would just add a bunch of overhead
    # to the --help option in order to remove 2 lines of code in the other branches, so we'll
    # just check for 'error' in each branch instead.
    declare -F error fatal trace >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"

    [[ $# -gt 0 ]] && error "${EXIT_USAGE:-2}" "Too many arguments"

    if [[ "${refresh}" == true ]]; then
        unset BWX_DEFAULT_PROJECT_ID
    fi

    if [[ -z "${BWX_DEFAULT_PROJECT_ID:-}" ]]; then
        for cmd in bwx-default-project-name bwx-project-list ; do
            declare -F "${cmd}" >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/${cmd}"
        done

        local project=
        project="$(bwx-default-project-name)"
        trace bwx-project-id "${project}"

        # Optimization: Call bwx-project-list directly and filter with jq to avoid
        # intermediate script overheads (bwx-project-id -> bws-project -> bwx-project-list).
        if ! BWX_DEFAULT_PROJECT_ID=$(bwx-project-list | jq -r --arg name "${project}" '.[] | select(.name == $name or .id == $name) | .id'); then
             fatal "${EXIT_ERROR:-1}" "Failed to lookup project '${project}'"
        fi

        [[ -z "${BWX_DEFAULT_PROJECT_ID}" ]] && fatal "${EXIT_NOTFOUND}" "BWS Default project '${project}' not found"
        export BWX_DEFAULT_PROJECT_ID
        trace "Exported BWX_DEFAULT_PROJECT_ID=${BWX_DEFAULT_PROJECT_ID}"
    fi

    echo "${BWX_DEFAULT_PROJECT_ID}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bwx-default-project-id "$@"
fi
