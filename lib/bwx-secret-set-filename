bwx-secret-set-filename() {
    set -o errexit -o errtrace -o nounset -o pipefail # Ensure robust error handling
    local _debug="${DEBUG:-false}"
    [[ "${_debug,,}" =~ ^(1|on|true|t|yes|y)$ ]] && set -o verbose -o xtrace # Enable debug output if DEBUG is set

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                declare -F bwx-default-project-name >/dev/null 2>&1 || \
                    source "$(dirname "${BASH_SOURCE[0]}")/bwx-default-project-name"
                cat <<EOF
Usage: bwx secret set filename SECRET FILENAME [PROJECT]

Set the filename matadata property for a Bitwarden Secrets Manager secret.

Arguments:
  SECRET      Secret name or UUID (required)
  FILENAME    New filename (required)
  PROJECT     Project name or UUID (optional) [default: $(bwx-default-project-name)]

Options:
  -h, --help  Display this help message
  -l, --log-level LEVEL  Set log level (default: info)
EOF
                return "${EXIT_USAGE:-2}"
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            *)
                break
                ;;
        esac
    done

    declare -F error trace >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
    for cmd in bwx-project-id bwx-project-name bwx-secret-id; do
        declare -F "${cmd}" >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/${cmd}"
    done

    local secret="${1:-}"
    [[ -n "${secret}" ]] || error "${EXIT_USAGE}" "Secret name or UUID required"
    local filename="${2:-}"
    [[ -n "${filename}" ]] || error "${EXIT_USAGE}" "File name required"
    local project="${3:-}"
    project="$(bwx-project-id "${project}")"
    local project_name
    project_name=$(bwx-project-name "${project}")

    local secret_uuid
    secret_uuid=$(bwx-secret-id "${secret}" "${project}" || :)
    if [[ -z "${secret_uuid:+x}" ]]; then
        local project_name
        project_name=$(bwx-project-name "${project}")
        error "${EXIT_NOTFOUND}" "Secret '${secret}' not found in project ${project_name}"
    fi

    local existing_notes
    trace "bwx-secret-set-filename: bws secret get '${secret_uuid}' | jq -r '.note'"
    existing_notes="$(bws secret get "${secret_uuid}" --output json | jq -r '.note')"
    echo "existing_notes:${existing_notes}" | trace

    local new_notes=
    new_notes=$(echo "${existing_notes}" | grep -vE '^file:')
    debug "new_notes=${new_notes}"
    new_notes=$(echo "${new_notes}" && echo "file: ${filename}")
    debug "new_notes=${new_notes}"
    new_notes=$(echo "${new_notes}"  | sort -u)
    debug "new_notes=${new_notes}"
    trace "bwx-secret-set-filename: bws secret edit '${secret_uuid}' --note '${new_notes}'"
    if bws secret edit "${secret_uuid}" --note "${new_notes}" >/dev/null; then
        debug "Secret filename updated successfully"
    else
        error "${EXIT_ERROR}" "Failed to update secret filename"
    fi

    # Refresh the cached secret list for the project, if it exists, since we just updated
    # a secret note which is included in the secret list output
    if bwx-secret-list --refresh "${project}" >/dev/null 2>&1; then
        local secret_list_project="${project_name^^}"
        secret_list_project="${secret_list_project//-/_}"
        local secret_list_var="BWX_PROJECT_SECRET_LIST_${secret_list_project}"
        warn "Be sure to unset the cached secret list for project '${project_name}' (i.e. 'unset ${secret_list_var}') to ensure you get the updated data!!" || :
    else
        warn "Failed to refresh cached secret list for project '${project_name}' - subsequent secrets data is suspect!!" || :
    fi || :
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bwx-secret-set-filename "$@"
fi

