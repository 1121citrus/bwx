bws-secret-add-release-tag() {
    set -o errexit -o errtrace -o nounset -o pipefail # Ensure robust error handling
    local _debug="${DEBUG:-false}"
    [[ "${_debug,,}" =~ ^(1|on|true|t|yes|y)$ ]] && set -o verbose -o xtrace # Enable debug output if DEBUG is set

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                declare -F bws-default-project-name >/dev/null 2>&1 || \
                    source "$(dirname "${BASH_SOURCE[0]}")/bws-default-project-name"
                cat <<EOF
Usage: $(basename "${BASH_SOURCE[0]}") [options] SECRET TAG [PROJECT]

Adds a release tag to a Bitwarden Secrets Manager secret.

Arguments:
    SECRET       Secret name or UUID (required)
    TAG          The release tag to add to the secret (required)
    PROJECT      Project name or UUID (optional) [default: $(bws-default-project-name)]

Options:
    -h, --help   Display this help message
    -l, --log-level LEVEL  Set log level (default: info)
    --           End of options; any remaining arguments will be treated as positional arguments

Returns SUCCESS if the release tag was added to the secret.

EOF
                return "${EXIT_USAGE:-2}"
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                error "${EXIT_USAGE}" "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done

    declare -F error trace >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
    for cmd in bws bws-default-project-name bws-project-name bws-secret-id bws-secret-list bws-secret-note; do
        declare -F "${cmd}" >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/${cmd}"
    done

    local secret="${1:-}" && shift || :
    [[ -n "${secret}" ]] || error "${EXIT_USAGE}" "Secret name or UUID required"

    local tag="${1:-}" && shift || :
    [[ -n "${tag}" ]] || error "${EXIT_USAGE}" "Tag name required"

    local project="${1:-}"
    if [[ -z "${project}" ]]; then
        project=$(bws-default-project-name)
    fi
    shift || :
    [[ -n "${project}" ]] || error "${EXIT_NOTFOUND}" "Project name or UUID not found"

    [[ "${#@}" -gt 0 ]] && error "${EXIT_USAGE}" "Too many arguments"

    local project_name
    project_name=$(bws-project-name "${project}")

    local secret_uuid
    secret_uuid=$(bws-secret-id "${secret}" "${project}" || :)
    if [[ -z "${secret_uuid}" ]]; then
        error "${EXIT_NOTFOUND}" "Secret '${secret}' not found in project ${project_name}"
    fi

    local existing_notes
    existing_notes="$(bws-secret-note "${secret_uuid}" "${project}")"
    { echo "secret '${secret_uuid}' existing notes:"; echo "${existing_notes}"; } | trace

    local new_notes
    new_notes=$(echo -e "${existing_notes}\nrelease-tag: ${tag}" | sort -u)
    trace "bws-secret-add-release-tag: bws secret edit '${secret_uuid}' --note '${new_notes}'"
    if bws secret edit "${secret_uuid}" --note "${new_notes}" >/dev/null; then
        info "Added release tag '${tag}' to secret '${secret}' in project '${project_name}'"
    else
        error "${EXIT_ERROR}" "Failed to add release tag '${tag}' to secret '${secret}' in project '${project_name}'"
    fi

    # Refresh the cached secret list unless a bulk caller defers it until the end.
    if ! is-true "${BWS_SKIP_SECRET_LIST_REFRESH:-false}"; then
        if bws-secret-list --refresh "${project}" >/dev/null 2>&1; then
            debug "Refreshed cached secret list for project '${project_name}'" || :
        else
            warn "Failed to refresh cached secret list for project '${project_name}'" || :
        fi
    fi || :
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bws-secret-add-release-tag "$@"
fi

