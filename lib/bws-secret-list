function bws-secret-list() {
    set -o errexit -o errtrace -o nounset -o pipefail # Ensure robust error handling
    local _debug="${DEBUG:-false}"
    [[ "${_debug,,}" =~ ^(1|on|true|t|yes|y)$ ]] && set -o verbose -o xtrace # Enable debug output if DEBUG is set

    declare -F error trace >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
    declare -F bws-cache-dir >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/bws-cache"

    trace "Retrieving secret list from cache or Bitwarden Secrets Manager API: '$(basename "${BASH_SOURCE[0]}") $*'"

    local export_secret_list='' output_keys='' refresh=''
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -e|--export)
                export_secret_list=true
                trace "export_secret_list=true"
                shift
                ;;
            -k|--keys)
                output_keys=true
                trace "output_keys=true"
                shift
                ;;
            -h|--help)
                declare -F bws-default-project-name >/dev/null 2>&1 || \
                    source "$(dirname "${BASH_SOURCE[0]}")/bws-default-project-name"
                cat <<EOF
Usage: bws-secret-list [options] [PROJECT]

Prints a Bitwarden Secrets Manager project's secret list as JSON.

Arguments:
    PROJECT        Project name or UUID (optional) [default: $(bws-default-project-name)]

Options:
    -e, --export   Print an expression to set BWS_PROJECT_SECRET_LIST_<PROJECT> environment variable in the current shell
    -k, --keys     Print secret names (keys), one per line
    -h, --help     Display this help message
    -l, --log-level LEVEL  Set log level (default: info)
    -R, --refresh  Refresh the cached secret list

This function caches it's result in an environment variable name based on project name
(i.e. BWS_PROJECT_SECRET_LIST_<PROJECT>). It stores the raw JSON secret list for the project
to avoid re-fetching.

To include the secret list into the current shell, use the --export option (i.e. 'eval "\$(bws-secret-list --export PROJECT)"').

To refresh the secret list, unset the variable before calling this function or 'eval "\$(bws-secret-list --export PROJECT)"'.

EOF
                return "${EXIT_USAGE:-2}"
                ;;
            -R|--refresh)
                refresh='true'
                trace "refresh=true"
                shift
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                error "${EXIT_USAGE:-2}" "Unknown option '${1}'"
                break
                ;;
            *)
                break
                ;;
        esac
    done

    for cmd in bws bws-default-project-name bws-project-id jq; do
        declare -F "${cmd}" >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/${cmd}"
    done
    local project_input="${1:-}"
    local project=
    local project_id=
    local project_key=
    local uuid_regex='^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$'

    if [[ -z "${project_input}" ]]; then
        project_input=$(bws-default-project-name)
    fi

    if [[ "${project_input}" =~ ${uuid_regex} ]]; then
        project_id="${project_input}"
        project_key="${project_input}"
    else
        project="${project_input}"
        project_key="${project_input}"
    fi
    shift || :
    [[ -n "${project_key}" ]] || error "${EXIT_USAGE}" "Project name or UUID required"
    [[ "${#@}" -gt 0 ]] && error "${EXIT_USAGE}" "Too many arguments"

    # SECRET_LIST variable name based on project name is all uppercase with hyphens replaced by underscores
    # i.e. BWS_PROJECT_SECRET_LIST_<PROJECT>, it stores the raw JSON secret list for the project to avoid re-fetching.
    # To include the SECRET_LIST in the current shell, use the --export option (i.e. eval "$(bws-secret-list --export PROJECT)").
    # To refresh the secret list, unset the variable before calling this function or pass the '--refresh' option.
    local SECRET_LIST=
    local SECRET_ID_CACHE=
    local SECRET_NAME_CACHE=
    local sanitized_project
    sanitized_project=$(LC_ALL='en_US.UTF-8' awk '{print toupper($0)}' <<<"${project_key//[^[:alnum:]]/_}")
    SECRET_LIST="BWS_PROJECT_SECRET_LIST_${sanitized_project}"
    SECRET_ID_CACHE="BWS_PROJECT_SECRET_ID_CACHE_${sanitized_project}"
    SECRET_NAME_CACHE="BWS_PROJECT_SECRET_NAME_CACHE_${sanitized_project}"

    local cache_ttl="${BWS_SECRET_LIST_CACHE_TTL_SECONDS:-300}"
    local cache_scope="${BWS_SERVER_BASE_URL:-https://vault.bitwarden.com}|${BWS_ACCESS_TOKEN:-}|${project_key}"
    local cache_file=
    local resolved_cache_file=
    local id_cache_file=
    local name_cache_file=
    local resolved_id_cache_file=
    local resolved_name_cache_file=
    cache_file=$(bws-cache-file "secret-list" "${cache_scope}" "json" 2>/dev/null || :)
    id_cache_file=$(bws-cache-file "secret-id-map" "${cache_scope}" "tsv" 2>/dev/null || :)
    name_cache_file=$(bws-cache-file "secret-name-map" "${cache_scope}" "tsv" 2>/dev/null || :)

    if [[ -n "${refresh}" ]]; then
        export "${SECRET_LIST}="
        export "${SECRET_ID_CACHE}="
        export "${SECRET_NAME_CACHE}="
        [[ -n "${cache_file}" ]] && bws-cache-delete "${cache_file}"
        [[ -n "${id_cache_file}" ]] && bws-cache-delete "${id_cache_file}"
        [[ -n "${name_cache_file}" ]] && bws-cache-delete "${name_cache_file}"
    fi

    local summary_length="${BWS_SECRET_LIST_SUMMARY_LENGTH:-50}"
    readonly summary_length

    local secrets="${!SECRET_LIST:-}"

    if [[ -n "${secrets}" ]]; then
        if ! printf '%s' "${secrets}" | jq -e '.' >/dev/null 2>&1; then
            warn "Cached secret list for project '${project_key}' is invalid; refreshing"
            export "${SECRET_LIST}="
            export "${SECRET_ID_CACHE}="
            export "${SECRET_NAME_CACHE}="
            [[ -n "${cache_file}" ]] && bws-cache-delete "${cache_file}"
            secrets=""
        fi
    fi

    if [[ -z "${secrets}" && -n "${cache_file}" ]]; then
        secrets=$(bws-cache-read "${cache_file}" "${cache_ttl}" 2>/dev/null || :)
    fi

    if [[ -n "${secrets}" ]]; then
        if ! printf '%s' "${secrets}" | jq -e '.' >/dev/null 2>&1; then
            warn "Secret list file cache for project '${project_key}' is invalid; refreshing"
            export "${SECRET_LIST}="
            export "${SECRET_ID_CACHE}="
            export "${SECRET_NAME_CACHE}="
            [[ -n "${cache_file}" ]] && bws-cache-delete "${cache_file}"
            secrets=""
        fi
    fi

    if [[ -z "${secrets}" && -z "${project_id}" ]]; then
        project_id=$(bws-project-id "${project}")
        resolved_cache_file=$(bws-cache-file \
            "secret-list" \
            "${BWS_SERVER_BASE_URL:-https://vault.bitwarden.com}|${BWS_ACCESS_TOKEN:-}|${project_id}" \
            "json" 2>/dev/null || :)
        resolved_id_cache_file=$(bws-cache-file \
            "secret-id-map" \
            "${BWS_SERVER_BASE_URL:-https://vault.bitwarden.com}|${BWS_ACCESS_TOKEN:-}|${project_id}" \
            "tsv" 2>/dev/null || :)
        resolved_name_cache_file=$(bws-cache-file \
            "secret-name-map" \
            "${BWS_SERVER_BASE_URL:-https://vault.bitwarden.com}|${BWS_ACCESS_TOKEN:-}|${project_id}" \
            "tsv" 2>/dev/null || :)
        if [[ -n "${refresh}" && -n "${resolved_cache_file}" ]]; then
            bws-cache-delete "${resolved_cache_file}"
        fi
        if [[ -n "${refresh}" ]]; then
            [[ -n "${resolved_id_cache_file}" ]] && bws-cache-delete "${resolved_id_cache_file}"
            [[ -n "${resolved_name_cache_file}" ]] && bws-cache-delete "${resolved_name_cache_file}"
        fi
        if [[ -z "${secrets}" && -n "${resolved_cache_file}" ]]; then
            secrets=$(bws-cache-read "${resolved_cache_file}" "${cache_ttl}" 2>/dev/null || :)
        fi
    fi

    if [[ -z "${secrets}" ]]; then
        if [[ -z "${project_id}" ]]; then
            project_id=$(bws-project-id "${project}")
        fi
        trace "bws-secret-list bws secret list '${project_id}'"
        if ! secrets=$(bws secret list "${project_id}" --output json </dev/null | jq -c .); then
            error "${EXIT_ERROR:-1}" "Failed to retrieve secrets from Bitwarden Secrets Manager"
        fi
        [[ -z "${secrets}" ]] && error "${EXIT_NOTFOUND}" "No secrets found in Bitwarden Secrets Manager project '${project_key}'"
        printf -v "${SECRET_LIST}" '%s' "${secrets}"
        # shellcheck disable=SC2163
        export "${SECRET_LIST}"
        debug "Exported ${SECRET_LIST}=${!SECRET_LIST:0:${summary_length}}..."
        [[ -n "${cache_file}" ]] && bws-cache-write "${cache_file}" "${secrets}"
        if [[ -n "${project_id}" && "${project_id}" != "${project_key}" ]]; then
            [[ -n "${resolved_cache_file}" ]] || resolved_cache_file=$(bws-cache-file \
                "secret-list" \
                "${BWS_SERVER_BASE_URL:-https://vault.bitwarden.com}|${BWS_ACCESS_TOKEN:-}|${project_id}" \
                "json" 2>/dev/null || :)
            [[ -n "${resolved_cache_file}" ]] && bws-cache-write "${resolved_cache_file}" "${secrets}"
        fi
    elif [[ "${!SECRET_LIST:-}" != "${secrets}" ]]; then
        printf -v "${SECRET_LIST}" '%s' "${secrets}"
        # shellcheck disable=SC2163
        export "${SECRET_LIST}"
    fi

    if [[ -z "${!SECRET_ID_CACHE:-}" && -n "${id_cache_file}" ]]; then
        printf -v "${SECRET_ID_CACHE}" '%s' "$(bws-cache-read "${id_cache_file}" "${cache_ttl}" 2>/dev/null || :)"
    fi
    if [[ -z "${!SECRET_NAME_CACHE:-}" && -n "${name_cache_file}" ]]; then
        printf -v "${SECRET_NAME_CACHE}" '%s' "$(bws-cache-read "${name_cache_file}" "${cache_ttl}" 2>/dev/null || :)"
    fi
    if [[ -z "${!SECRET_ID_CACHE:-}" && -n "${resolved_id_cache_file}" ]]; then
        printf -v "${SECRET_ID_CACHE}" '%s' "$(bws-cache-read "${resolved_id_cache_file}" "${cache_ttl}" 2>/dev/null || :)"
    fi
    if [[ -z "${!SECRET_NAME_CACHE:-}" && -n "${resolved_name_cache_file}" ]]; then
        printf -v "${SECRET_NAME_CACHE}" '%s' "$(bws-cache-read "${resolved_name_cache_file}" "${cache_ttl}" 2>/dev/null || :)"
    fi

    if [[ -z "${!SECRET_ID_CACHE:-}" || -z "${!SECRET_NAME_CACHE:-}" ]]; then
        local cache_id_data
        local cache_name_data
        cache_id_data=$(printf '%s' "${!SECRET_LIST}" | jq -r '.[] | "\(.key)\t\(.id)"' || : )
        cache_name_data=$(printf '%s' "${!SECRET_LIST}" | jq -r '.[] | "\(.id)\t\(.key)"' || : )
        printf -v "${SECRET_ID_CACHE}" '%s' "${cache_id_data}"
        printf -v "${SECRET_NAME_CACHE}" '%s' "${cache_name_data}"
        # shellcheck disable=SC2163
        export "${SECRET_ID_CACHE}" "${SECRET_NAME_CACHE}"
        [[ -n "${id_cache_file}" ]] && bws-cache-write "${id_cache_file}" "${cache_id_data}"
        [[ -n "${name_cache_file}" ]] && bws-cache-write "${name_cache_file}" "${cache_name_data}"
        if [[ -n "${resolved_id_cache_file}" ]]; then
            bws-cache-write "${resolved_id_cache_file}" "${cache_id_data}"
        fi
        if [[ -n "${resolved_name_cache_file}" ]]; then
            bws-cache-write "${resolved_name_cache_file}" "${cache_name_data}"
        fi
    fi

    if [[ -n "${export_secret_list}" ]]; then
        # Safely quote the JSON for evaluation
        printf "export %s=%q\n" "${SECRET_LIST}" "${!SECRET_LIST}"
        if [[ -n "${!SECRET_ID_CACHE:-}" ]]; then
            printf "export %s=%q\n" "${SECRET_ID_CACHE}" "${!SECRET_ID_CACHE}"
        fi
        if [[ -n "${!SECRET_NAME_CACHE:-}" ]]; then
            printf "export %s=%q\n" "${SECRET_NAME_CACHE}" "${!SECRET_NAME_CACHE}"
        fi
    elif [[ -n "${output_keys}" ]]; then
        if [[ -n "${!SECRET_ID_CACHE:-}" ]]; then
            printf '%s\n' "${!SECRET_ID_CACHE}" | awk -F '\t' 'NF {print $1}' | LC_ALL='C' sort -u
        fi
    else
        secrets="${!SECRET_LIST}"
        debug "Returning secrets from ${SECRET_LIST}: ${secrets:0:${summary_length}}..."
        [[ -n "${secrets}" ]] && echo "${secrets}"
    fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bws-secret-list "$@"
fi

