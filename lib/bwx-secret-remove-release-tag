bwx-secret-remove-release-tag() {
    set -o errexit -o errtrace -o nounset -o pipefail # Ensure robust error handling
    local _debug="${DEBUG:-false}"
    [[ "${_debug,,}" =~ ^(1|on|true|t|yes|y)$ ]] && set -o verbose -o xtrace # Enable debug output if DEBUG is set

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                declare -F bwx-default-project-name >/dev/null 2>&1 || \
                    source "$(dirname "${BASH_SOURCE[0]}")/bwx-default-project-name"
                cat <<EOF
Usage: bwx tag remove [options] SECRET TAG [PROJECT]

Removes a release tag from a Bitwarden Secrets Manager secret.

Arguments:
  SECRET       Secret name or UUID (required)
  TAG          The release tag to remove from the secret
  PROJECT      Project name or UUID (optional) [default: $(bwx-default-project-name)]

Options:
  -h, --help   Display this help message
  -l, --log-level LEVEL  Set log level (default: info)

Returns SUCCESS if the release tag was removed from the secret.

EOF
                return "${EXIT_USAGE:-2}"
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            *)
                break
                ;;
        esac
    done

    declare -F error trace >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
    for cmd in bwx-default-project-name bwx-project-name bwx-secret-id bwx-secret-list bwx-secret-note; do
        declare -F "${cmd}" >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/${cmd}"
    done

    local secret="${1:-}" && shift || :
    [[ -n "${secret}" ]] || error "${EXIT_USAGE}" "Secret name or UUID required"

    local tag="${1:-}" && shift || :
    [[ -n "${tag}" ]] || error "${EXIT_USAGE}" "Tag name required"

    local project="${1:-}"
    if [[ -z "${project}" ]]; then
        project=$(bwx-default-project-name)
    fi
    shift || :
    [[ -n "${project}" ]] || error "${EXIT_NOTFOUND}" "Project name or UUID not found"
    [[ "${#@}" -gt 0 ]] && error "${EXIT_USAGE}" "Too many arguments"

    local project_name
    project_name=$(bwx-project-name "${project}")

    local secret_uuid
    secret_uuid=$(bwx-secret-id "${secret}" "${project}" || :)
    if [[ -z "${secret_uuid:+x}" ]]; then
        error "${EXIT_NOTFOUND}" "Secret '${secret}' not found in project ${project_name}"
    fi

    local existing_notes
    existing_notes="$(bwx-secret-note "${secret_uuid}" "${project}")"
    { echo "secret '${secret_uuid}' existing notes:" && echo "${existing_notes}"; } | trace

    local new_notes
    local release_tag_line="release-tag: ${tag}"
    new_notes=$(
        printf '%s\n' "${existing_notes}" |
            awk -v release_tag_line="${release_tag_line}" '$0 != release_tag_line' |
            sort -u
    )
    trace "bwx-secret-remove-release-tag: bws secret edit '${secret_uuid}' --note '${new_notes}'"
    if bws secret edit "${secret_uuid}" --note "${new_notes}" >/dev/null; then
        info "Removed release tag '${tag}' from secret '${secret}' in project '${project_name}'"
    else
        error "${EXIT_ERROR}" "Failed to remove release tag '${tag}' from secret '${secret}' in project '${project_name}'"
    fi

    # Refresh the cached secret list unless a bulk caller defers it until the end.
    if ! is-true "${BWX_SKIP_SECRET_LIST_REFRESH:-false}"; then
        if bwx-secret-list --refresh "${project}" >/dev/null 2>&1; then
            debug "Refreshed cached secret list for project '${project_name}'" || :
        else
            warn "Failed to refresh cached secret list for project '${project_name}'" || :
        fi
    fi || :
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bwx-secret-remove-release-tag "$@"
fi

