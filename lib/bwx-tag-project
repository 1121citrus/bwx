# Add a release tag to all (or selected) secrets in a project.
# Supports --select-tag to limit scope to secrets carrying a given tag.
# Args:
#   $1 — release tag to add
#   $@ — optional secret names or --select-tag filters
# Returns:
#   0 if all updates succeed; 1 if any individual update fails
bwx-tag-project() {
    set -o errexit -o errtrace -o nounset -o pipefail # Ensure robust error handling
    # DEBUG xtrace omitted — secret values may flow through callee chain

    local bindir
    source "$(cd "$(dirname "${BASH_SOURCE[0]}")/../include" && pwd)/path"
    bindir="$(bwx-script-dir "${BASH_SOURCE[0]}")"

    declare -F error trace >/dev/null 2>&1 || source "${bindir}/../include/logging"

    local project=""
    local -a select_tags=()

    local refresh=
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                declare -F bwx-default-project-name >/dev/null 2>&1 || \
                    source "${bindir}/bwx-default-project-name"
                cat <<EOF
Usage: bwx tag project [OPTIONS] RELEASE_TAG [SECRETS...]

Adds a release tag to specified secrets in a project.

Secrets can be specified by name or UUID.

The tag will be added to all specified secrets. If the --select-tag option is used, then the
secrets with the specified tag will also be tagged. If no secrets or select tags are specified,
then the tag will be added to all secrets in the project. The --select-tag option may be repeated.

The project can be specified by name or UUID; if not specified, the default project will
be used.

Arguments:
    RELEASE_TAG The release tag to add to the selected secrets (required)
    SECRETS...  Optional list of secrets to update; if not specified, all secrets
                with the specified release tag will be updated. If neither SECRETS
                nor --select-tag is specified, then all the secrets in the project
                will be used.

Options:
    -h, --help   Display this help message
    -l, --log-level LEVEL  Set log level (default: info)
    -p, --project Specify the project name or UUID (default: $(bwx-default-project-name))
    -s, --select-tag Specify the release tag to select secrets (supplements SECRETS with
                 secrets that have the SELECT_TAG release tag; may be repeated)
    -R, --refresh  Refresh the cached secret list
    --          End of options; any remaining arguments will be treated as secrets to update

Returns SUCCESS if all secrets were updated.
EOF
                return "${EXIT_USAGE:-2}"
                ;;
            -R|--refresh)
                refresh="true"
                shift
                ;;
            -p|--project)
                [[ -n "${2:-}" ]] || error "${EXIT_USAGE}" "PROJECT required"
                project="$2"
                shift 2
                ;;
            -s|--select-tag)
                [[ -n "${2:-}" ]] || error "${EXIT_USAGE}" "SELECT_TAG required"
                select_tags+=("${2}")
                shift 2
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                error "${EXIT_USAGE}" "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done

    local release_tag="${1:-}"
    [[ -n "${release_tag}" ]] || error "${EXIT_USAGE}" "RELEASE_TAG required"
    shift || :

    local -a cli_secrets=()
    if [[ "$#" -gt 0 ]]; then
        cli_secrets=("$@")
    fi

    for cmd in bwx-default-project-name bwx-project-id bwx-secret-add-release-tag bwx-secret-list ; do
        declare -F "${cmd}" >/dev/null 2>&1 || source "${bindir}/${cmd}"
    done
    declare -F bwx-note-release-tag-jq-filter >/dev/null 2>&1 || \
        source "${bindir}/../include/note-parser"

    local uuid_regex='^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$'
    if [[ -z "${project}" ]]; then
        project=$(bwx-default-project-name)
    fi
    local project_id
    if [[ "${project}" =~ ${uuid_regex} ]]; then
        project_id="${project}"
    else
        project_id="$(bwx-project-id "${project}" || : )"
    fi
    [[ -n "${project_id}" ]] || error "${EXIT_NOTFOUND}" "Project name or UUID not found: '${project}'"
    trace "project-id for project '${project:-}': ${project_id}" || :

    # Purely for performance; cache the secrets list in the environment.
    local secret_list
    if [[ -n "${refresh}" ]]; then
        secret_list="$(bwx-secret-list --refresh --export "${project_id}" 2>/dev/null || : )"
    else
        secret_list="$(bwx-secret-list --export "${project_id}" 2>/dev/null || : )"
    fi
    [[ -n "${secret_list:+x}" ]] || error "${EXIT_ERROR}" "Failed to retrieve secret list for project '${1:-}'"
    eval "${secret_list}"

    local sanitized_project
    local _sanitize_tmp="${project_id//[^[:alnum:]]/_}"
    sanitized_project="${_sanitize_tmp^^}"
    local secret_list_var="BWX_PROJECT_SECRET_LIST_${sanitized_project}"
    local release_tag_filter
    release_tag_filter="$(bwx-note-release-tag-jq-filter)"

    # Return secret keys that carry a specific release tag.
    secrets_for_tag() {
        local tag="$1"
        printf '%s' "${!secret_list_var}" | \
            jq -r --arg tag "${tag}" "${release_tag_filter}"'.[] | select((.note | bwx_note_release_tags) | index($tag)) | .key' || :
    }

    # Return all secret keys in the project.
    list_all_secrets() {
        printf '%s' "${!secret_list_var}" | jq -r '.[].key' || :
    }

    local -a tag_secrets=()
    if [[ "${#select_tags[@]}" -gt 0 ]]; then
        local tag
        for tag in "${select_tags[@]}"; do
            mapfile -t tag_matches < <(secrets_for_tag "${tag}")
            if [[ "${#tag_matches[@]}" -gt 0 ]]; then
                tag_secrets+=("${tag_matches[@]}")
                trace "Secrets for tag '${tag}': ${tag_matches[*]}" || :
            fi
        done
    fi
    trace "Secrets selected by tag: ${tag_secrets[*]:-}"

    local -a selected_secrets=("${cli_secrets[@]}" "${tag_secrets[@]}")
    if [[ "${#selected_secrets[@]}" -eq 0 && "${#select_tags[@]}" -eq 0 ]]; then
        trace "No secrets specified on the command line or by select tags; selecting all secrets in project '${project_id}'" || :
        mapfile -t selected_secrets < <(list_all_secrets)
    fi

    if [[ "${#selected_secrets[@]}" -eq 0 ]]; then
        warn "No secrets selected for release tag '${release_tag}'" || :
        return "${RETURN_SUCCESS}"
    fi

    local -a unique_secrets=()
    mapfile -t unique_secrets < <(printf '%s\n' "${selected_secrets[@]}" | sort -u)
    info "Unique secrets to tag for release '${release_tag}': ${unique_secrets[*]:-}" || :

    local processed=0
    local failed=0
    local secret
    for secret in "${unique_secrets[@]}"; do
        [[ -n "${secret}" ]] || continue
        debug "Adding tag '${release_tag}' to secret '${secret}'"
        trace "bwx-secret-add-release-tag '${secret}' '${release_tag}' '${project_id}'" || :
        if BWX_SKIP_SECRET_LIST_REFRESH=true \
            bwx-secret-add-release-tag "${secret}" "${release_tag}" "${project_id}"; then
            info "Added tag '${release_tag}' to secret '${secret}'" || :
        else
            warn "Failed to add tag '${release_tag}' to secret '${secret}'"
            ((failed++)) || :
        fi
        ((processed++)) || :
    done

    if [[ "${processed}" -gt 0 ]]; then
        bwx-secret-list --refresh "${project_id}" >/dev/null 2>&1 || \
            warn "Failed to refresh cached secret list for project '${project_id}' after tagging" || :
    fi

    [[ "${processed}" -eq 0 ]] && warn "No secrets selected for release tag '${release_tag}'" || :
    [[ "${failed}" -eq 0 ]] || return "${RETURN_ERROR}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bwx-tag-project "$@"
fi
