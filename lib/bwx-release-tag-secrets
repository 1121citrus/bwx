# List secrets that carry a specific release tag.
# Args:
#   $1 — release tag name
#   $2 — project name or UUID (optional)
# Returns:
#   0 and writes one secret key per line to stdout
bwx-release-tag-secrets() {
    set -o errexit -o errtrace -o nounset -o pipefail # Ensure robust error handling
    # DEBUG xtrace omitted — secret values may flow through callee chain

    local bindir
    bindir=$(CDPATH='' cd -- "${BASH_SOURCE[0]%/*}" && pwd)

    local refresh_flag=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                declare -F bwx-default-project-name >/dev/null 2>&1 || \
                    source "${bindir}/bwx-default-project-name"
                cat <<EOF
Usage: bwx tag secrets [OPTIONS] [RELEASE] [PROJECT]

Displays the secrets having the specified release tag.

Arguments:
    RELEASE      The release tag to filter secrets (optional)
    PROJECT      Project name or UUID (optional) [default: $(bwx-default-project-name)]

Options:
    -h, --help     Display this help message
    -l, --log-level LEVEL  Set log level (default: info)
    -R, --refresh  Refresh the cached secret list

Security Warning: This function uses the RELEASE argument to filter secrets by release
without additional validation. Ensure that the RELEASE argument is sanitized if supplied
by untrusted input, as it is used in filtering.

Returns SUCCESS if all secrets were updated.
EOF
                return "${EXIT_USAGE:-2}"
                ;;
            -R|--refresh)
                refresh_flag="--refresh"
                shift
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            *)
                break
                ;;
        esac
    done

    declare -F error trace >/dev/null 2>&1 || source "${bindir}/../include/logging"
    declare -F bwx-note-release-tag-jq-filter >/dev/null 2>&1 || \
        source "${bindir}/../include/note-parser"

    trace "Return secrets with release tags from cache or Bitwarden Secrets Manager API: '$(basename "${BASH_SOURCE[0]}") $*'" >/dev/stderr || :

    # shellcheck disable=SC2043
    for cmd in bwx-secret-list; do
        declare -F "${cmd}" >/dev/null 2>&1 || source "${bindir}/${cmd}"
    done

    local release="${1:-}"
    shift || :
    local project="${1:-}"
    debug "project: '${project}', release: '${release}'"

    local release_tag_filter
    release_tag_filter="$(bwx-note-release-tag-jq-filter)"
    bwx-secret-list ${refresh_flag} "${project}" | \
        jq -r --arg rel "${release}" "${release_tag_filter}"'[.[]
            | {key, tags: (.note | bwx_note_release_tags)}
            | select(.tags | length > 0)
            | .tags[] as $tag
            | {tag: $tag, key}]
            | (if $rel != "" then map(select(.tag == $rel)) else . end)
            | group_by(.tag)
            | map("\(.[0].tag): \(map(.key) | sort | join(" "))")
            | .[]' | \
        sort -u || :
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bwx-release-tag-secrets "$@"
fi
