# Return the name of the default project.
# Uses BWX_DEFAULT_PROJECT if set, otherwise queries the BWS project
# list and selects the first (or only) project.
# Args:
#   None
# Returns:
#   0 and writes project name to stdout; EXIT_CONFIG if undetermined
bwx-default-project-name() {
    set -o errexit -o errtrace -o nounset -o pipefail
    # DEBUG xtrace omitted — secret values may flow through callee chain

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: bwx project default name [options]

Print the name of the default Bitwarden Secrets Manager project.

Environment variables:
    BWX_DEFAULT_PROJECT  Explicit default project name

Options:
    -h, --help   Display this help message
    -l, --log-level LEVEL  Set log level (default: info)
EOF
                return "${EXIT_USAGE:-2}"
                ;;
            -l|--log-level)
                [[ -n "${2:-}" && "${2}" != -* ]] || \
                    error "${EXIT_USAGE}" "--log-level requires a value"
                LOG_LEVEL="${2}"
                export LOG_LEVEL
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -*)
                declare -F error >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
                error "${EXIT_USAGE:-2}" "Unknown option '${1}'"
                ;;
            *)
                declare -F error >/dev/null 2>&1 || source "$(dirname "${BASH_SOURCE[0]}")/../include/logging"
                error "${EXIT_USAGE:-2}" "Too many arguments '${*}'"
                ;;
        esac
    done

    echo "${BWX_DEFAULT_PROJECT:-}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    bwx-default-project-name "$@"
fi
