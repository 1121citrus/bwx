#!/usr/bin/env bash

# build — local CI equivalent for bwx.
#
# Copyright (C) 2026 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# SYNOPSIS
#   build [--push] [--version VERSION]
#         [--platform PLATFORMS] [--registry REGISTRY]
#         [--no-sbom] [--no-provenance]
#         [--no-lint] [--no-test]
#         [--run-staging]
#         [--no-scan]
#         [--advise [ADVISEMENTS]] [--advice [ADVISEMENTS]] [--no-advise]
#         [--cache CACHE_RULES]
#         [--dry-run] [--help]
#
# OPTIONS
#   --push              Push the image to the registry after a successful build.
#                       Omitting this flag builds locally only (the default).
#   --version VERSION   Tag the image with this version string, e.g. "1.2.3".
#                       When omitted the image is tagged "dev-<git-short-sha>"
#                       so that local builds are never confused with released
#                       artifacts.
#   --platform PLATFORMS
#                       Comma-separated list of target platforms for --push.
#                       Default: linux/amd64,linux/arm64
#   --registry REGISTRY Docker Hub username / registry prefix.
#                       Default: 1121citrus
#   --no-sbom           Skip generating an SBOM attestation (push only).
#   --no-provenance     Skip generating a provenance attestation (push only).
#   --no-lint           Skip hadolint Dockerfile check and shellcheck.
#   --no-test           Skip running the test suite.
#   --run-staging       Run test/staging after Stage 3 test. Default: off.
#   --no-scan           Skip all gating vulnerability scans (Trivy, Grype,
#                       Scout). Also skips advisory scans by default; pass
#                       --advise after --no-scan to keep them.
#   --advise [ADVISEMENTS]
#                       Run advisory scans. Comma-delimited list:
#                       'churn', 'coverage', 'dive', 'metrics', 'security',
#                       'all', 'none', or any combination.
#                       'all' selects every available advisement.
#                       'none' disables all (equivalent to --no-advise).
#                       Default with no list given: 'all'.
#                       Advisory scans are off by default.
#   --advice [ADVISEMENTS]
#                       Synonym for --advise.
#   --no-advise         Disable all advisory scans (equivalent to
#                       --advise none).
#   --cache CACHE_RULES One-run cache controls for scanner DBs.
#                       Rule format: 'reset=<targets>;skip-update=<targets>'
#                       Targets: trivy, grype, all (comma-delimited)
#                       Examples:
#                         --cache 'reset=all'
#                         --cache 'skip-update=grype'
#                         --cache 'reset=grype;skip-update=trivy'
#   --dry-run           Print each command without executing it.
#   --help              Print this message and exit.
#
# ENVIRONMENT
#   The following env-var overrides take precedence over the defaults above but
#   are themselves overridden by the matching CLI flag:
#     BUILD_VERSION, BUILD_PUSH, BUILD_PLATFORM, BUILD_REGISTRY
#     BUILD_LINT, BUILD_TEST, BUILD_SCAN, BUILD_SCAN_GRYPE, BUILD_SCAN_SCOUT
#     BUILD_REPORT_JSON
#     BUILD_TEST_SUMMARY_JSON
#     BUILD_RUN_STAGING
#     BUILD_STAGING_SUMMARY_JSON
#   BUILD_CACHE_WARN_DAYS
#                       Warn when the Trivy or Grype DB is older than this
#                       many days. Default: 1. Set to 0 to suppress.
#
# PREREQUISITES
#   • docker with the buildx plugin (≥ 0.10)
#   • For --push: docker login <registry> must already be authenticated, plus
#     QEMU binfmt helpers for cross-platform builds:
#       docker run --rm --privileged tonistiigi/binfmt --install all
#
# STAGES (run in order; each can be skipped with --no-<stage>)
#   1.  Lint      — hadolint (Dockerfile) + shellcheck + markdownlint
#   2.  Build     — single-platform --load into local Docker daemon
#   3.  Test      — bats test suite
#   3d. Staging   — optional integration harness (only with --run-staging)
#   4.  Scan      — Trivy CRITICAL/HIGH image scan (gating)
#   4b. Scan      — Grype full-severity scan (gating)
#   4c. Scan      — Docker Scout CVE scan (gating)
#   5.  Advise    — advisory scans (never block the build)
#              a) Dive       — image layer analysis
#              b) Coverage   — kcov line-coverage report
#              f) Metrics    — scc code-metrics summary
#   6.  Push      — multi-platform rebuild + push (only with --push)
#
# EXAMPLES
#   # Local dev cycle — lint, build, test, scan
#   ./build
#
#   # Full scan including advisory
#   ./build --advise all
#
#   # Release build — push version 1.2.3 and latest
#   ./build --push --version 1.2.3
#
#   # Skip scanning during fast iteration
#   ./build --no-scan
#
#   # Reset scanner DB caches for this run
#   ./build --cache 'reset=all'
#
#   # Dry-run: just print each command
#   ./build --dry-run
#
# HELP_ENDS_HERE

set -euo pipefail

# ---------------------------------------------------------------------------
# Developer orientation
#
# This script is the local equivalent of the CI workflow. Run it before
# pushing to verify that every quality gate passes. Each stage can be
# skipped individually (see OPTIONS above).
#
# Scanner DB caches persist in Docker named volumes between runs. The first
# run primes the cache from the internet; later runs skip the download.
# Use --cache reset=all to force a fresh download before a release scan.
#
# --dry-run prints every command without executing it — useful for
# understanding what a stage does before running it for the first time.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Defaults — may be overridden by environment variables or CLI flags.
# ---------------------------------------------------------------------------
SCAN=${BUILD_SCAN:-true}
ADVISE_METRICS=false
ADVISE_COVERAGE=false
_ADVISE_EXPLICIT=false   # set true when --advise or --no-advise is passed
CACHE_RESET_TRIVY=false
CACHE_RESET_GRYPE=false
CACHE_SKIP_UPDATE_TRIVY=false
CACHE_SKIP_UPDATE_GRYPE=false
DRY_RUN=false
BUILD_REPORT_JSON=${BUILD_REPORT_JSON:-}
LINT=${BUILD_LINT:-true}
PLATFORMS=${BUILD_PLATFORM:-linux/amd64,linux/arm64}
PROVENANCE=true
PUSH=${BUILD_PUSH:-false}
REGISTRY=${BUILD_REGISTRY:-1121citrus}
SBOM=true
TEST=${BUILD_TEST:-true}
TEST_SUMMARY_JSON=${BUILD_TEST_SUMMARY_JSON:-}
RUN_STAGING=${BUILD_RUN_STAGING:-false}
STAGING_SUMMARY_JSON=${BUILD_STAGING_SUMMARY_JSON:-}
if [[ -n "${BUILD_REPORT_JSON}" && -z "${TEST_SUMMARY_JSON}" ]]; then TEST_SUMMARY_JSON="${BUILD_REPORT_JSON%.json}.test.json"; fi
if [[ -n "${BUILD_REPORT_JSON}" && -z "${STAGING_SUMMARY_JSON}" ]]; then STAGING_SUMMARY_JSON="${BUILD_REPORT_JSON%.json}.staging.json"; fi
VERSION=${BUILD_VERSION:-}

IMAGE_NAME=bwx

# Tool image references — edit these variables to update tool versions.
BATS_KCOV_IMAGE=1121citrus/bats-kcov
BATS_KCOV_TAG=latest
HADOLINT_IMAGE=hadolint/hadolint
HADOLINT_TAG=v2.14.0
MARKDOWNLINT_IMAGE=ghcr.io/igorshubovych/markdownlint-cli
MARKDOWNLINT_TAG=v0.48.0
SCC_IMAGE=ghcr.io/boyter/scc
SCC_TAG=v3.7.0
SHELLCHECK_IMAGE=koalaman/shellcheck
SHELLCHECK_TAG=v0.11.0
TRIVY_IMAGE=aquasec/trivy
TRIVY_TAG=0.70.0

TRIVY_CACHE_VOLUME=bwx-trivy-cache

# ---------------------------------------------------------------------------
# Helpers: cache control parsing
# ---------------------------------------------------------------------------
# set_cache_targets — set cache-control flags for the named scanner targets.
# Called by parse_cache_rules for each key=value pair from --cache.
# Args: $1=mode (reset|skip-update)  $2=targets_csv (trivy,grype,all)
set_cache_targets() {
    local mode="$1"
    local targets_csv="$2"
    local target
    IFS=',' read -ra _cache_targets <<< "${targets_csv}"

    for target in "${_cache_targets[@]}"; do
        case "${target}" in
            trivy)
                if [[ "${mode}" == "reset" ]]; then
                    CACHE_RESET_TRIVY=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    CACHE_SKIP_UPDATE_TRIVY=true
                fi
                ;;
            grype)
                if [[ "${mode}" == "reset" ]]; then
                    CACHE_RESET_GRYPE=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            all)
                if [[ "${mode}" == "reset" ]]; then
                    CACHE_RESET_TRIVY=true
                    CACHE_RESET_GRYPE=true
                elif [[ "${mode}" == "skip-update" ]]; then
                    CACHE_SKIP_UPDATE_TRIVY=true
                    CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            *)
                echo "Unknown cache target: ${target}" >&2
                exit 1
                ;;
        esac
    done
}

# parse_cache_rules — parse the --cache flag value and dispatch to
# set_cache_targets.  Accepts semicolon-separated key=value pairs
# (e.g. "reset=trivy;skip-update=grype").  Exits 1 on malformed input.
# Args: $1=rules (semicolon-separated string)
parse_cache_rules() {
    local rules="$1"
    local entry
    local key
    local value
    IFS=';' read -ra _cache_rules <<< "${rules}"

    for entry in "${_cache_rules[@]}"; do
        key="${entry%%=*}"
        value="${entry#*=}"
        key="${key//[[:space:]]/}"
        value="${value//[[:space:]]/}"
        key="${key,,}"
        value="${value,,}"

        if [[ -z "${key}" && -z "${value}" ]]; then
            continue
        fi

        if [[ "${entry}" != *=* || -z "${key}" || -z "${value}" ]]; then
            echo "Invalid --cache rule: ${entry}" >&2
            exit 1
        fi

        case "${key}" in
            reset|skip-update)
                set_cache_targets "${key}" "${value}"
                ;;
            *)
                echo "Unknown --cache rule key: ${key}" >&2
                exit 1
                ;;
        esac
    done
}

# volume_has_file — return 0 if file_path exists inside a Docker volume.
# Runs an Alpine container to perform the check so it is host-filesystem-
# agnostic.  Always returns 1 in dry-run mode (safe-fail).
# Args: $1=volume_name  $2=file_path (absolute path inside the volume)
volume_has_file() {
    local volume_name="$1"
    local file_path="$2"

    if [[ "${DRY_RUN}" == "true" ]]; then
        return 1
    fi

    docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.20 \
        sh -c "test -f \"${file_path}\""
}

# grype_db_ready — return 0 if the Grype vulnerability database is present
# and valid inside the cache volume.  Runs `grype db status` inside a
# container so it uses the same paths as the actual scan.  Always returns 1
# in dry-run mode (safe-fail).
# Args: $1=volume_name
grype_db_ready() {
    local volume_name="$1"

    if [[ "${DRY_RUN}" == "true" ]]; then
        return 1
    fi

    docker run --rm \
        -e "GRYPE_DB_CACHE_DIR=${GRYPE_DB_CACHE_DIR}" \
        -v "${volume_name}:${GRYPE_DB_CACHE_DIR}" \
        "${GRYPE_IMAGE}:${GRYPE_TAG}" db status >/dev/null 2>&1
}

# reset_cache_db — wipe and recreate a Docker volume used as a scanner DB
# cache (Trivy or Grype).  Runs Alpine inside a container so the operation
# is cross-platform and independent of host filesystem permissions.
# Args: $1=volume_name
reset_cache_db() {
    local volume_name="$1"
    # Reset the volume by removing all contents and recreating the directory.
    run docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.21 \
        sh -c "rm -rf /cache/* && mkdir -p /cache"
}

# ---------------------------------------------------------------------------
# Helper: execute a command or print it for --dry-run.
# ---------------------------------------------------------------------------
run() {
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN]" "$@" >&2
    else
        "$@"
    fi
}

# Run a command with a timeout (no external 'timeout' binary required).
# Backgrounds the command, starts a watchdog that kills it after SECONDS,
# then waits.  In --dry-run mode just prints the command.
# Usage: _timed SECONDS COMMAND [ARGS...]
_timed() {
    local secs="$1"; shift
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] (${secs}s timeout)" "$@" >&2
        return 0
    fi
    "$@" &
    local _pid=$!
    ( sleep "${secs}" && kill "${_pid}" 2>/dev/null ) &
    local _watcher=$!
    wait "${_pid}" 2>/dev/null; local _rc=$?
    kill "${_watcher}" 2>/dev/null
    wait "${_watcher}" 2>/dev/null || true
    return "${_rc}"
}

# Build report helper: writes optional aggregate JSON report combining
# test and staging summary artifacts.
write_build_report() {
    if [[ -z "${BUILD_REPORT_JSON:-}" ]]; then
        return 0
    fi

    local test_json="null"
    local staging_json="null"

    if [[ -n "${TEST_SUMMARY_JSON:-}" && -f "${TEST_SUMMARY_JSON}" ]]; then
        test_json=$(cat "${TEST_SUMMARY_JSON}")
    fi

    if [[ -n "${STAGING_SUMMARY_JSON:-}" && -f "${STAGING_SUMMARY_JSON}" ]]; then
        staging_json=$(cat "${STAGING_SUMMARY_JSON}")
    fi

    mkdir -p "$(dirname "${BUILD_REPORT_JSON}")"

    cat > "${BUILD_REPORT_JSON}" <<EOF
{
  "kind": "build-report",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "image": "${full_image}:${VERSION}",
  "test": ${test_json},
  "staging": ${staging_json}
}
EOF

    echo "    report: ${BUILD_REPORT_JSON}" >&2
    if [[ -n "${TEST_SUMMARY_JSON:-}" ]]; then
        echo "    report section test: ${TEST_SUMMARY_JSON}" >&2
    fi
    if [[ -n "${STAGING_SUMMARY_JSON:-}" ]]; then
        echo "    report section staging: ${STAGING_SUMMARY_JSON}" >&2
    fi
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
_require_value() {
    local option="$1"
    local value="${2:-}"
    if [[ -z "${value}" || "${value}" == --* ]]; then
        echo "${option} requires a value" >&2
        exit 1
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --push)             PUSH=true ;;
        --version)          _require_value "$1" "${2:-}"; VERSION="$2"; shift ;;
        --platform)         _require_value "$1" "${2:-}"; PLATFORMS="$2"; shift ;;
        --registry)         _require_value "$1" "${2:-}"; REGISTRY="$2"; shift ;;
        --no-sbom)          SBOM=false ;;
        --no-provenance)    PROVENANCE=false ;;
        --no-lint)          LINT=false ;;
        --no-test)          TEST=false ;;
        --run-staging)      RUN_STAGING=true ;;
        --no-scan)
            SCAN=false
            ;;
        --advise|--advice)
            _ADVISE_EXPLICIT=true
            # Check if next arg looks like an advisement list (no -- prefix)
            if [[ $# -gt 1 && ! "$2" =~ ^-- ]]; then
                advisements="$2"; shift
            else
                advisements="all"
            fi
            # Parse the comma-delimited list
            ADVISE_METRICS=false
            ADVISE_COVERAGE=false
            IFS=',' read -ra adv_list <<< "$advisements"
            for adv in "${adv_list[@]}"; do
                adv="${adv//[[:space:]]/}"
                adv="${adv,,}"
                case "$adv" in
                    coverage) ADVISE_COVERAGE=true ;;
                    metrics)  ADVISE_METRICS=true ;;
                    all)
                        ADVISE_METRICS=true
                        ADVISE_COVERAGE=true
                        ;;
                    none)
                        ADVISE_METRICS=false
                        ADVISE_COVERAGE=false
                        ;;
                    *)  echo "Unknown advisement: $adv" >&2; exit 1 ;;
                esac
            done
            ;;
        --no-advise)
            ADVISE_METRICS=false
            ADVISE_COVERAGE=false
            _ADVISE_EXPLICIT=true
            ;;
        --cache)
            if [[ $# -lt 2 || "$2" =~ ^-- ]]; then
                echo "--cache requires CACHE_RULES" >&2
                exit 1
            fi
            parse_cache_rules "$2"
            shift
            ;;
        --dry-run)          DRY_RUN=true ;;
        --help|-h)
            sed -n '3,/^# HELP_ENDS_HERE/p' "$0" \
                | grep '^#' \
                | sed 's/^# \{0,1\}//' \
                | head -n -1
            exit 0 ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1 ;;
    esac
    shift
done

# --no-scan implies --no-advise unless --advise was given explicitly.
if [[ "${SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
    ADVISE_METRICS=false
    ADVISE_COVERAGE=false
fi

# ---------------------------------------------------------------------------
# Resolve the image version tag.
# ---------------------------------------------------------------------------
if [[ -z "${VERSION}" ]]; then
    sha=$(git -C "$(dirname "$0")" rev-parse --short HEAD 2>/dev/null \
        || echo "unknown")
    VERSION="dev-${sha}"
fi

# ---------------------------------------------------------------------------
# Construct the tag list.
# Dev builds are tagged as both dev-<commit> and dev-latest.
# "latest" is only added for non-dev (release) builds that will be pushed.
# ---------------------------------------------------------------------------
full_image="${REGISTRY}/${IMAGE_NAME}"
tags=("--tag" "${full_image}:${VERSION}")
if [[ "${VERSION}" == dev-* ]]; then
    tags+=("--tag" "${full_image}:dev-latest")
fi
if [[ "${PUSH}" == "true" && "${VERSION}" != dev-* ]]; then
    tags+=("--tag" "${full_image}:latest")
fi

# Script directory for build context and relative paths.
script_dir=$(dirname "$(readlink -f "$0")")

echo "Version:   ${VERSION}" >&2

# ---------------------------------------------------------------------------
# Stage 1: Lint
# ---------------------------------------------------------------------------
if [[ "${LINT}" == "true" ]]; then
    echo "==> Stage 1: Lint" >&2
    echo "    shellcheck bash scripts" >&2
    (cd "${script_dir}" && run docker run --rm \
        -v "${script_dir}:/src:ro" \
        --workdir /src \
        "${SHELLCHECK_IMAGE}:${SHELLCHECK_TAG}" \
            -S warning \
 \
            /src/bin/bwx \
            /src/include/logging \
            /src/include/bwx-cache \
            /src/include/tools)

    echo "    markdownlint **/*.md" >&2
    run docker run --rm \
        -v "${script_dir}:/md:ro" \
        --workdir /md \
        "${MARKDOWNLINT_IMAGE}:${MARKDOWNLINT_TAG}" \
            '**/*.md'
fi

# ---------------------------------------------------------------------------
# Stage 3: Test
# ---------------------------------------------------------------------------
if [[ "${TEST}" == "true" ]]; then
    echo "==> Stage 3: Test" >&2
    if [[ -x "${script_dir}/test/run-all" ]]; then
        (cd "${script_dir}" && IMAGE="${full_image}:${VERSION}" TEST_SUMMARY_JSON="${TEST_SUMMARY_JSON}" run ./test/run-all)
    else
    run docker run -i --rm \
        -v "${script_dir}:/code:ro" \
        -w /code \
        bats/bats:1.13.0 \
            test/bin/bwx.bats \
            test/bin/bwx-secret.bats \
            test/bin/bwx-project.bats \
            test/bin/bwx-tag.bats
    fi
    write_build_report
fi

# ---------------------------------------------------------------------------
# Stage 3d: Staging (optional)
# Runs test/staging only when explicitly requested with --run-staging.
# ---------------------------------------------------------------------------
if [[ "${RUN_STAGING}" == "true" ]]; then
    echo "==> Stage 3d: Staging" >&2
    if [[ ! -x "${script_dir}/test/staging" ]]; then
        echo "    SKIP: test/staging not found or not executable" >&2
    else
        (cd "${script_dir}" && run env STAGING_SUMMARY_JSON="${STAGING_SUMMARY_JSON}" ./test/staging)
    fi
    write_build_report
fi

# ---------------------------------------------------------------------------
# Stage 4: Scan dependency images (advisory — does not block the build)
# ---------------------------------------------------------------------------
if [[ "${SCAN}" == "true" ]]; then
    echo "==> Stage 4: Scan dependency images" >&2
    _dep_scan_failed=0

    echo "    scanning apteno/alpine-jq" >&2
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] trivy image apteno/alpine-jq" >&2
    else
        run docker run --rm \
            -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
            "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
                --quiet \
                --no-progress \
                --ignore-unfixed \
                --severity HIGH,CRITICAL \
                --timeout 5m \
                "apteno/alpine-jq" || {
            echo "    WARN: apteno/alpine-jq has HIGH/CRITICAL CVEs" >&2
            _dep_scan_failed=1
        }
    fi

    echo "    scanning bitwarden/bws:latest" >&2
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] trivy image bitwarden/bws:latest" >&2
    else
        run docker run --rm \
            -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
            "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
                --quiet \
                --no-progress \
                --ignore-unfixed \
                --severity HIGH,CRITICAL \
                --timeout 5m \
                "bitwarden/bws:latest" || {
            echo "    WARN: bitwarden/bws:latest has HIGH/CRITICAL CVEs" >&2
            _dep_scan_failed=1
        }
    fi

    echo "    scanning curlimages/curl" >&2
    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] trivy image curlimages/curl" >&2
    else
        run docker run --rm \
            -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
            "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
                --quiet \
                --no-progress \
                --ignore-unfixed \
                --severity HIGH,CRITICAL \
                --timeout 5m \
                "curlimages/curl" || {
            echo "    WARN: curlimages/curl has HIGH/CRITICAL CVEs" >&2
            _dep_scan_failed=1
        }
    fi

    if [[ "${_dep_scan_failed}" -ne 0 ]]; then
        echo "    One or more dependency images have CVEs (advisory only)" >&2
    else
        echo "    All dependency images clean" >&2
    fi
fi

# ---------------------------------------------------------------------------
# Stage 5d: Coverage (kcov — advisory, never blocks)
#
# Reruns the bats suite through kcov to produce a per-file line-coverage
# report for src/.  Uses 1121citrus/bats-kcov (kcov + bats + jq pre-bundled).
# Requires SYS_PTRACE; works on macOS Docker Desktop with the flags below.
# ---------------------------------------------------------------------------
if [[ "${ADVISE_COVERAGE}" == "true" ]]; then
    echo "==> Stage 5d: Coverage" >&2

    if [[ "${DRY_RUN}" == "true" ]]; then
        echo "[DRY RUN] docker run --rm --cap-add SYS_PTRACE --security-opt seccomp=unconfined \\" >&2
        echo "[DRY RUN]   -v ${script_dir}:/code:ro -w /code ${BATS_KCOV_IMAGE}:${BATS_KCOV_TAG} bats-coverage <test files>" >&2
    else
        docker run --rm \
            --cap-add SYS_PTRACE \
            --security-opt seccomp=unconfined \
            -v "${script_dir}:/code:ro" \
            -w /code \
            "${BATS_KCOV_IMAGE}:${BATS_KCOV_TAG}" \
            bats-coverage \
                --src /code/lib --include /code/lib,/code/bin \
                test/bin/bwx.bats \
                test/bin/bwx-secret.bats \
                test/bin/bwx-secret-queries.bats \
                test/bin/bwx-project.bats \
                test/bin/bwx-project-queries.bats \
                test/bin/bwx-tag.bats \
                test/bin/bwx-tag-ops.bats \
                test/bin/bwx-mutations.bats \
                test/bin/bwx-http.bats \
            >&2 || echo "    Coverage run failed (advisory only)" >&2
    fi
fi

# ---------------------------------------------------------------------------
# Stage 5f: Advise (scc — code metrics)
# Counts source lines by language.  Results printed to stderr.
# Never blocks the build.
# ---------------------------------------------------------------------------
if [[ "${ADVISE_METRICS}" == "true" ]]; then
    echo "==> Stage 5f: Advise (metrics) ${full_image}:${VERSION}" >&2
    docker run --rm \
        -v "${script_dir}:/data:ro" \
        "${SCC_IMAGE}:${SCC_TAG}" \
        scc --by-file /data >&2 || true
fi

echo "" >&2
echo "Done: bwx ${VERSION}" >&2
