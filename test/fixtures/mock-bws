if [[ "$1" == "secret" && "$2" == "create" ]]; then
    # secret create [--note NOTE] KEY VALUE PROJECT_ID
    # Parse out the key from positional args (skip --note/--note-file flags)
    local_key=""
    shift 2
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --note|--note-file) shift 2 ;;
            -*) shift ;;
            *)
                if [[ -z "${local_key}" ]]; then
                    local_key="$1"
                fi
                shift
