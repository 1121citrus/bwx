declare -F bwx-cache-dir >/dev/null 2>&1 || {
    # Return the cache directory path, creating it if needed.
    # Honors BWX_CACHE_DIR, then XDG_CACHE_HOME, then ~/.cache/bwx.
    # Args:
    #   None
    # Returns:
    #   0 and writes directory path to stdout; 1 if creation fails
    bwx-cache-dir() {
        if [[ "${CITRUS_ENABLE_MOCK_COMMANDS:-false}" == "true" && -z "${BWX_CACHE_DIR:-}" ]]; then
            return 1
        fi

        local cache_dir="${BWX_CACHE_DIR:-${XDG_CACHE_HOME:-${HOME}/.cache}/bwx}"
        mkdir -p "${cache_dir}" || return 1
        chmod 700 "${cache_dir}" 2>/dev/null || :
        printf '%s\n' "${cache_dir}"
    }

    # Compute a SHA-256 hash of the given arguments.
    # Requires a SHA implementation; refuses to fall back to a
    # collision-prone digest (cksum CRC32) that could let unrelated
    # cache keys share a file.
    # Args:
    #   $@ — values to hash (concatenated)
    # Returns:
    #   0 and writes hex digest to stdout; 1 if no SHA tool is found
    bwx-cache-hash() {
        if [[ -x /usr/bin/shasum ]]; then
            printf '%s' "$*" | /usr/bin/shasum -a 256 | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            printf '%s' "$*" | shasum -a 256 | awk '{print $1}'
        elif command -v sha256sum >/dev/null 2>&1; then
            printf '%s' "$*" | sha256sum | awk '{print $1}'
        else
            printf 'bwx-cache-hash: no SHA-256 implementation found ' >&2
            printf '(install coreutils or shasum)\n' >&2
            return 1
        fi
    }

    # Build a cache file path from a namespace and key.
    # Args:
    #   $1 — namespace (e.g., "secrets", "projects")
    #   $2 — cache key (hashed to form the filename)
    #   $3 — file extension (default: "json")
    # Returns:
    #   0 and writes file path to stdout; 1 if cache dir unavailable
    #   or no SHA-256 implementation is available
    bwx-cache-file() {
        local namespace="${1:?Need namespace}"
        local cache_key="${2:?Need cache key}"
        local extension="${3:-json}"
        local cache_dir hash
        cache_dir=$(bwx-cache-dir) || return 1
        hash=$(bwx-cache-hash "${cache_key}") || return 1
        printf '%s/%s-%s.%s\n' \
            "${cache_dir}" \
            "${namespace}" \
            "${hash}" \
            "${extension}"
    }

    # Return the modification time of a file as epoch seconds.
    # Tries date -r, stat --format, then stat -f for portability.
    # Args:
    #   $1 — file path
    # Returns:
    #   0 and writes epoch seconds to stdout; non-zero on failure
    bwx-cache-mtime() {
        local cache_file="${1:?Need cache file}"
        date -r "${cache_file}" '+%s' 2>/dev/null || \
            stat --format='%Y' "${cache_file}" 2>/dev/null || \
            stat -f '%m' "${cache_file}" 2>/dev/null
    }

    # Test whether a cache file exists and is within its TTL.
    # Args:
    #   $1 — cache file path
    #   $2 — TTL in seconds (0 or non-numeric = always stale)
    # Returns:
    #   0 if fresh; 1 if missing, unreadable, or expired
    bwx-cache-is-fresh() {
        local cache_file="${1:?Need cache file}"
        local ttl="${2:-0}"
        [[ -r "${cache_file}" ]] || return 1
        [[ "${ttl}" =~ ^[0-9]+$ ]] || ttl=0
        (( ttl > 0 )) || return 1

        local now mtime
        now=$(date '+%s') || return 1
        mtime=$(bwx-cache-mtime "${cache_file}") || return 1
        (( now - mtime <= ttl ))
    }

    # Read a cache file if it is still fresh.
    # Args:
    #   $1 — cache file path
    #   $2 — TTL in seconds
    # Returns:
    #   0 and writes file contents to stdout; 1 if stale or missing
    bwx-cache-read() {
        local cache_file="${1:?Need cache file}"
        local ttl="${2:-0}"
        bwx-cache-is-fresh "${cache_file}" "${ttl}" || return 1
        cat "${cache_file}"
    }

    # Write a payload to a cache file atomically.
    # Uses a temp file and mv to avoid partial reads. Sets 600
    # permissions on the file and 700 on the directory.
    # Args:
    #   $1 — cache file path
    #   $2 — payload string
    # Returns:
    #   0 on success; 1 on write failure
    bwx-cache-write() {
        local cache_file="${1:?Need cache file}"
        local payload="${2-}"
        local cache_dir temp_file

        cache_dir=$(dirname "${cache_file}")
        mkdir -p "${cache_dir}" || return 1
        chmod 700 "${cache_dir}" 2>/dev/null || :

        temp_file=$(mktemp "${cache_dir}/.$(basename "${cache_file}").XXXXXX") || return 1
        (
            umask 077
            printf '%s' "${payload}" > "${temp_file}"
        ) || {
            rm -f "${temp_file}" >/dev/null 2>&1 || :
            return 1
        }
        chmod 600 "${temp_file}" 2>/dev/null || :
        mv -f "${temp_file}" "${cache_file}"
    }

    # Delete a cache file and any associated temp fragments.
    # Args:
    #   $1 — cache file path
    # Returns:
    #   0 (always succeeds silently)
    bwx-cache-delete() {
        local cache_file="${1:?Need cache file}"
        rm -f -- "${cache_file}" "${cache_file}.tmp."* >/dev/null 2>&1 || :
    }
}
