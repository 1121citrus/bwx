#!/usr/bin/env bash
# shellcheck shell=bash

# Docker-wrapped tool functions for commands not universally installed.
# Source this file to get jq and bws as local functions when they are
# not natively available.  The functions run Docker containers
# transparently — no user-visible difference from native commands.

