#!/usr/bin/env bash
# shellcheck shell=bash

# Centralized parser for BWS structured note metadata.
#
# Structured notes use a simple key: value format, one field per line.
# This module provides the single authoritative grammar for parsing,
# validating, and mutating note fields. All command modules should use
# these functions instead of inline grep/sed/jq pipelines.

