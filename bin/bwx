#!/usr/bin/env bash
# shellcheck shell=bash
# shellcheck disable=SC1090,SC1091

# bwx — Bitwarden Secrets Manager eXtended CLI.
#
# Single entry point with subcommand dispatch.  Internal functions
# use bwx-* function names internally; the dispatch
# layer maps space-separated subcommands to function calls.
#
# Usage: bwx <family> <command> [args...]
#        bwx completion bash
#        bwx --help

# Copyright (C) 2026 James Hanlon [mailto:jim@hanlonsoftware.com]
# Licensed under AGPL-3.0-or-later.

set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

# Minimum bash version guard — associative arrays, mapfile, and case
# transforms require bash 4.0+.  macOS ships bash 3.2 by default.
if (( BASH_VERSINFO[0] < 4 )); then
    printf 'bwx requires bash 4.0 or later (found %s)\n' \
        "${BASH_VERSION}" >&2
    printf 'On macOS, install via Homebrew: brew install bash\n' >&2
    exit 1
fi

resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local target
    local dir

    while [[ -L "${source}" ]]; do
        if ! command -v readlink >/dev/null 2>&1; then
            break
        fi

        target=$(readlink "${source}") || break
        if [[ "${target}" == /* ]]; then
            source="${target}"
        else
            dir=$(cd "$(dirname "${source}")" && pwd)
            source="${dir}/${target}"
        fi
    done

    cd "$(dirname "${source}")" && pwd
}

script_dir="$(resolve_script_dir)"

BWX_ROOT="$(cd "${script_dir}/.." && pwd)"
readonly BWX_ROOT

# Source includes via BWX_ROOT so a single relocation point (the value
# patched by the Homebrew formula) controls every lookup, including the
# path helpers that were previously sourced relative to script_dir.
source "${BWX_ROOT}/include/path"
source "${BWX_ROOT}/include/logging"
source "${BWX_ROOT}/include/bwx-cache"
source "${BWX_ROOT}/include/tools"
source "${BWX_ROOT}/include/http"
source "${BWX_ROOT}/include/note-parser"

# Source all library functions
for _bwx_lib in "${BWX_ROOT}"/lib/bwx*; do
    [[ -f "${_bwx_lib}" ]] && source "${_bwx_lib}"
done
unset _bwx_lib

# Dispatch table: maps space-separated subcommand paths to functions.
# Key format: "family/command[/subcommand]"
# To add a subcommand: add one line to this table and implement the
# function.  Completion and error messages derive from the table
# automatically.
declare -A _BWX_COMMANDS=(
    # secret family
    [secret/clone]=bwx-secret-clone
    [secret/create]=bwx-create-secret
    [secret/delete]=bwx-secret-delete
    [secret/get]=bwx-secret-get
    [secret/set]=bwx-secret-set
    [secret/list]=bwx-secret-list
    [secret/ls]=bwx-secrets
    [secret/show]=bwx-secret
    # project family
    [project/default/id]=bwx-default-project-id
    [project/default/name]=bwx-default-project-name
    [project/id]=bwx-project-id
    [project/list]=bwx-project-list
    [project/ls]=bwx-projects
    [project/name]=bwx-project-name
    [project/show]=bwx-project
    # tag family
    [tag/add]=bwx-secret-add-release-tag
    [tag/list]=bwx-release-tags
    [tag/project]=bwx-tag-project
    [tag/remove]=bwx-secret-remove-release-tag
    [tag/secrets]=bwx-release-tag-secrets
    [tag/unproject]=bwx-untag-project
    # lifecycle
    [import]=bwx-import
    [check/expiry]=bwx-check-expiry
    [note/validate]=bwx-note-validate
    [rotate]=bwx-rotate
    # provider
    [provider/info]=bwx-provider-info
    # special
    [raw]=bws
    [completion/bash]=_bwx_completion_bash
    [completion/zsh]=_bwx_completion_zsh
)

# Dispatch a subcommand by building the lookup key from positional args.
# Tries 3-word, 2-word, then 1-word keys to support nested subcommands.
# Args:
#   $@ — subcommand words followed by arguments
# Returns:
#   Exit code from the dispatched function
_bwx_dispatch() {
    # Consume leading -- between subcommand words.  Only the first
    # three positional args are subcommand candidates; -- appearing
    # later is passed through to the target function.
    local -a head=()
    local count=0
    while [[ $# -gt 0 && "${count}" -lt 3 ]]; do
        if [[ "${1}" == "--" ]]; then
            shift
            continue
        fi
        head+=("${1}")
        shift
        count=$((count + 1))
    done
    set -- "${head[@]+"${head[@]}"}" "$@"

    local key fn

    # Try 3-word key: family/cmd/subcmd
    if [[ $# -ge 3 ]]; then
        key="${1}/${2}/${3}"
        fn="${_BWX_COMMANDS[${key}]:-}"
        if [[ -n "${fn}" ]]; then
            shift 3
            "${fn}" "$@"
            return $?
        fi
    fi

    # Try 2-word key: family/cmd
    if [[ $# -ge 2 ]]; then
        key="${1}/${2}"
        fn="${_BWX_COMMANDS[${key}]:-}"
        if [[ -n "${fn}" ]]; then
            shift 2
            "${fn}" "$@"
            return $?
        fi
    fi

    # Try 1-word key: family (for raw)
    if [[ $# -ge 1 ]]; then
        key="${1}"
        fn="${_BWX_COMMANDS[${key}]:-}"
        if [[ -n "${fn}" ]]; then
            shift 1
            "${fn}" "$@"
            return $?
        fi
    fi

    # No match — find the deepest valid prefix and show its subcommands
    local prefix valid

    # Try 2-word prefix first (e.g., "secret/set")
    if [[ $# -ge 3 ]]; then
        prefix="${1}/${2}"
        valid=$(_bwx_valid_commands "${prefix}")
        if [[ -n "${valid}" ]]; then
            _bwx_usage_error "${1} ${2}" "${3}" "${valid}"
            return $?
        fi
    fi

    # Try 1-word prefix (e.g., "secret")
    if [[ $# -ge 2 ]]; then
        prefix="${1}"
        valid=$(_bwx_valid_commands "${prefix}")
        if [[ -n "${valid}" ]]; then
            _bwx_usage_error "${1}" "${2}" "${valid}"
            return $?
        fi
    fi

    # Unknown top-level family
    valid=$(_bwx_valid_commands "")
    _bwx_usage_error "" "${1:-}" "${valid}"
}

# List valid subcommands for a prefix by scanning the dispatch table.
# Args:
#   $1 — prefix (e.g., "secret", "secret/set", or "" for top-level)
# Returns:
#   0; writes space-separated subcommand names to stdout
_bwx_valid_commands() {
    local prefix="${1}"
    local key child
    local -A seen=()
    for key in "${!_BWX_COMMANDS[@]}"; do
        if [[ -z "${prefix}" ]]; then
            child="${key%%/*}"
        elif [[ "${key}" == "${prefix}/"* ]]; then
            local rest="${key#"${prefix}/"}"
            child="${rest%%/*}"
        else
            continue
        fi
        seen["${child}"]=1
    done
    local result
    result="$(printf '%s\n' "${!seen[@]}" | sort | tr '\n' ' ')"
    printf '%s' "${result%% }"
}

# Print a usage error for an unknown subcommand.
# Args:
#   $1  context (e.g., "secret set")
#   $2  unknown command
#   $3  valid commands (space-separated)
# Returns:
#   EXIT_USAGE
_bwx_usage_error() {
    local context="${1}" unknown="${2}" valid="${3}"
    if [[ -n "${context}" ]]; then
        printf 'bwx %s: unknown command: %s\n' "${context}" "${unknown}" >&2
        printf 'Valid commands: %s\n' "${valid}" >&2
    else
        printf 'bwx: unknown command: %s\n' "${unknown}" >&2
        printf 'Valid commands: %s\n' "${valid}" >&2
    fi
    return "${EXIT_USAGE:-2}"
}

# Generate bash completion from the dispatch table.
# shellcheck disable=SC2016
# Args:
#   None
# Returns:
#   0; writes completion definition to stdout
_bwx_completion_bash() {
    local families level1 level2
    families=$(_bwx_valid_commands "")

    cat <<COMP_HEADER
_bwx_completions() {
    local cur prev
    COMPREPLY=()
    cur="\${COMP_WORDS[COMP_CWORD]}"
    prev="\${COMP_WORDS[COMP_CWORD-1]}"

    case "\${COMP_CWORD}" in
        1) COMPREPLY=(\$(compgen -W "${families}" -- "\${cur}")) ;;
        2)
            case "\${prev}" in
COMP_HEADER

    local fam
    for fam in ${families}; do
        level1=$(_bwx_valid_commands "${fam}")
        printf '                %s) COMPREPLY=($(compgen -W "%s" -- "${cur}")) ;;\n' \
            "${fam}" "${level1}"
    done

    cat <<'COMP_L2_HEADER'
            esac
            ;;
        3)
            case "${COMP_WORDS[1]}" in
COMP_L2_HEADER

    for fam in ${families}; do
        level1=$(_bwx_valid_commands "${fam}")
        for sub in ${level1}; do
            level2=$(_bwx_valid_commands "${fam}/${sub}")
            if [[ -n "${level2}" ]]; then
                printf '                %s)\n' "${fam}"
                printf '                    [[ "${prev}" == "%s" ]] && \\\n' "${sub}"
                printf '                        COMPREPLY=($(compgen -W "%s" -- "${cur}"))\n' \
                    "${level2}"
                printf '                    ;;\n'
            fi
        done
    done

    cat <<'COMP_FOOTER'
            esac
            ;;
    esac
}
complete -F _bwx_completions bwx
COMP_FOOTER
}

# Generate zsh completion.
# Args:
#   None
# Returns:
#   0; writes completion definition to stdout
_bwx_completion_zsh() {
    local families
    families=$(_bwx_valid_commands "")
    # shellcheck disable=SC2016
    printf '# Add to ~/.zshrc: eval "$(bwx completion zsh)"\n'
    printf 'compdef _bwx bwx\n'
    printf '_bwx() { _arguments "1:family:(%s)" }\n' "${families}"
}

# Print top-level usage.
# Args:
#   None
# Returns:
#   0
_bwx_usage() {
    local version
    version="$(<"${BWX_ROOT}/version.txt")" 2>/dev/null || version="dev"
    cat <<EOF
bwx ${version} — Bitwarden Secrets Manager eXtended CLI

Usage: bwx <command> [subcommand] [args...]

Commands:
    secret       Query and mutate secrets
    project      Query projects
    tag          Manage release tags
    import       Export secrets by release tag to a directory
    check        Check secret metadata (expiry dates)
    note         Note field operations (validate)
    rotate       Rotate time-limited secrets via provider drivers
    provider     Provider introspection (info)
    raw          Pass-through to the upstream bws binary
    completion   Generate shell completion (bash, zsh)

Secret commands:
    bwx secret list              List all secrets in a project
    bwx secret show SECRET       Show full secret details
    bwx secret get PROP SECRET   Get a property (value, note, id, key, filename, tags, ...)
    bwx secret set PROP SECRET V Set a property (value, note, key, filename)
    bwx secret list              List all secrets in a project
    bwx secret show SECRET       Show full secret details
    bwx secret ls                List secrets (summary format)
    bwx secret create ...        Create a new secret
    bwx secret clone SECRET      Clone with version increment
    bwx secret delete SECRET     Delete a secret by name or UUID

Project commands:
    bwx project list             List all projects
    bwx project show PROJECT     Show project details
    bwx project id PROJECT       Get a project's UUID
    bwx project name PROJECT     Get a project's name
    bwx project ls               List projects (summary format)
    bwx project default id       Get the default project UUID
    bwx project default name     Get the default project name

Tag commands:
    bwx tag list                 List all release tags
    bwx tag secrets TAG          List secrets tagged with TAG
    bwx tag add SECRET TAG       Add a release tag to a secret
    bwx tag remove SECRET TAG    Remove a release tag from a secret
    bwx tag project TAG          Tag all secrets in the project
    bwx tag unproject TAG        Remove tag from all secrets

Lifecycle commands:
    bwx import TAG DIR [PROJECT]     Export secrets by release tag
    bwx check expiry [--exit-on-expiring]  Check for expiring secrets
    bwx note validate SECRET [PROJ]  Validate note fields and provider config
    bwx rotate SECRET [PROJECT]      Rotate a secret via its provider
    bwx rotate --all [PROJECT]       Rotate all expiring secrets

Provider commands:
    bwx provider info NAME           Show expected config fields for a provider
    bwx provider info --list         List all available providers

Completion:
    eval "\$(bwx completion bash)"   Add to .bashrc
    eval "\$(bwx completion zsh)"    Add to .zshrc

Options:
    -h, --help                   Show this help
    -v, --version                Show version

Environment:
    BWS_ACCESS_TOKEN             Bitwarden Secrets Manager access token (required)
    BWX_DEFAULT_PROJECT          Default project name
    BWS_SERVER_BASE_URL          Bitwarden server URL
EOF
}

# Main entry point.
# Args:
#   "$@" — command-line arguments
# Returns:
#   Exit code from dispatched subcommand
main() {
    # Strip leading -- (end-of-options marker before subcommand words)
    while [[ "${1:-}" == "--" ]]; do shift; done

    case "${1:-}" in
        -h|--help|help|"")
            _bwx_usage
            return 0
            ;;
        -v|--version|version)
            cat "${BWX_ROOT}/version.txt"
            return 0
            ;;
    esac

    _bwx_dispatch "$@"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] || {
    printf 'bwx must be executed, not sourced\n' >&2
    return "${EXIT_USAGE:-2}"
}

main "$@"
